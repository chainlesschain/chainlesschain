diff --git a/.github/workflows/_cli-test.yml b/.github/workflows/_cli-test.yml
index 209c9e6d8..eec553030 100644
--- a/.github/workflows/_cli-test.yml
+++ b/.github/workflows/_cli-test.yml
@@ -14,15 +14,14 @@ name: _CLI Test (reusable)
 #
 # Required flags (DO NOT DROP):
 #   --shard=k/n        balanced file split (replaces glob batching)
-#   --silent=true      suppresses per-test stdout capture going over the
-#                      vitest worker→main RPC pipe (60s onTaskUpdate timeout).
-#                      Without this, a 4366-test shard locally exits 1 with
-#                      "[vitest-worker]: Timeout calling onTaskUpdate" even
-#                      though every test passes. This is standard vitest CI
-#                      practice, not a workaround. Note: vitest CAC parser
-#                      requires the explicit `=true` form when positional
-#                      file args follow.
-#   --reporter=basic   minimal reporter output (less IPC traffic)
+#
+# `silent: true` and `reporters: ['basic']` are pinned in
+# packages/cli/vitest.config.js + vitest.e2e.config.js (not on the CLI
+# invocation here) so local `npx vitest run` matches CI behavior. Without
+# silent, the worker→main RPC pipe saturates past the 60s onTaskUpdate
+# timeout on verbose suites — a 4366-test shard locally exits 1 with
+# "[vitest-worker]: Timeout calling onTaskUpdate" even though every test
+# passes. This is standard vitest CI practice, not a workaround.
 #
 # Inputs:
 #   runs-on    — runner OS (default ubuntu-latest)
@@ -66,7 +65,7 @@ jobs:
       - uses: ./.github/actions/setup-node-deps
       - name: vitest unit shard ${{ matrix.shard }}/${{ inputs.shards }}
         working-directory: packages/cli
-        run: npx vitest run --shard=${{ matrix.shard }}/${{ inputs.shards }} --reporter=basic --silent=true __tests__/unit/
+        run: npx vitest run --shard=${{ matrix.shard }}/${{ inputs.shards }} __tests__/unit/
 
   integration:
     name: "integration (${{ inputs.runs-on }}, shard ${{ matrix.shard }}/${{ inputs.shards }})"
@@ -85,7 +84,7 @@ jobs:
       - uses: ./.github/actions/setup-node-deps
       - name: vitest integration shard ${{ matrix.shard }}/${{ inputs.shards }}
         working-directory: packages/cli
-        run: npx vitest run --shard=${{ matrix.shard }}/${{ inputs.shards }} --reporter=basic --silent=true __tests__/integration/
+        run: npx vitest run --shard=${{ matrix.shard }}/${{ inputs.shards }} __tests__/integration/
 
   e2e:
     name: "e2e (${{ inputs.runs-on }}, shard ${{ matrix.shard }}/${{ inputs.shards }})"
@@ -105,4 +104,4 @@ jobs:
       - uses: ./.github/actions/setup-node-deps
       - name: vitest e2e shard ${{ matrix.shard }}/${{ inputs.shards }}
         working-directory: packages/cli
-        run: npx vitest run --config vitest.e2e.config.js --shard=${{ matrix.shard }}/${{ inputs.shards }} --reporter=basic --silent=true __tests__/e2e/
+        run: npx vitest run --config vitest.e2e.config.js --shard=${{ matrix.shard }}/${{ inputs.shards }} __tests__/e2e/

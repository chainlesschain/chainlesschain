echo "🚀 运行 Pre-push 检查门禁..."
echo ""

# 获取当前分支
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
echo "📌 当前分支: $BRANCH"
echo ""

# 0. 版本号一致性 (productVersion ↔ desktop / iOS / Android)
# 防 v5.0.3.53→57 Android 漂移类问题 (UpdateChecker 拿 BuildConfig.VERSION_NAME 比对 release tag)
echo "🔢 版本号一致性检查..."
node scripts/check-version-sync.js
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 版本号不一致 — 请同步所有表面后再 push"
  echo "   常见漏 bump 表面: android-app/app/build.gradle.kts (versionName + versionCode)"
  echo "   ios-app/.../Info.plist (CFBundleVersion)"
  echo ""
  echo "如需跳过检查（不推荐 — 会让 in-app 自动更新失效），使用: git push --no-verify"
  exit 1
fi
echo ""

# 0.5 PDH bundle staleness (traps #27 + #28)
# 改 packages/personal-data-hub/lib/** 或 packages/cli/lib/** 后必须同步 bump
#   - android-app/feature-local-terminal/build.gradle.kts USR_VERSION (trap #27)
#   - packages/personal-data-hub/package.json version + cli dep (trap #28)
# 不 bump → 设备装新 APK 但 cc 子进程仍跑旧代码，silent 失效。
# pre-push 用 @{u} (upstream tracking branch) 当 base，本地 push 场景天然对。
echo "📦 PDH bundle staleness 检查 (traps #27 + #28)..."
# Resolve upstream tracking branch; if missing (first push of a new branch),
# skip the check — the PR gate (pdh-bundle-staleness-check.yml) will run
# against origin/<base_ref> and authoritative.
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
if [ -z "$UPSTREAM" ]; then
  echo "   (未设 upstream tracking，跳过本地检查 — PR gate 会跑)"
else
  node scripts/lint-pdh-bundle-staleness.mjs --base=@{u}
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ PDH bundle staleness 检查失败 — 见上方 violation 列表"
    echo "   trap #27: USR_VERSION 没 bump → 真机 fast-path 跳过解压用旧代码"
    echo "   trap #28: workspace 包没 bump + publish → cc-cli.tgz 拉 npm registry 旧版"
    echo ""
    echo "如需跳过检查（不推荐 — silent 失效会浪费数小时调试），使用: git push --no-verify"
    exit 1
  fi
fi
echo ""

# 进入 desktop-app-vue 目录
cd desktop-app-vue || exit 1

# 1. 运行 TypeScript 类型检查
echo "🔷 运行 TypeScript 类型检查..."
npm run type-check

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ TypeScript 类型检查失败！"
  echo "请修复类型错误后再推送"
  echo ""
  echo "如需跳过检查（不推荐），使用: git push --no-verify"
  exit 1
fi

echo "✅ TypeScript 类型检查通过"
echo ""

# 注意: 数据库测试和 MCP 测试已移至 CI/CD 流水线
# 这些测试需要特定环境，在本地 pre-push 中容易超时或失败
# 完整测试请运行: npm run test:unit

echo "🎉 所有必要检查通过，允许推送！"
echo ""
echo "💡 提示: 完整单元测试请运行: cd desktop-app-vue && npm run test:unit"

echo "🔍 运行 Pre-commit 代码质量门禁..."
echo ""

START_TIME=$(date +%s)

# 0. 工作树快照（防 lint-staged --no-stash 数据丢失，参见 memory feedback_lint_staged_no_stash_data_loss）
# 恢复：tail .git/last-precommit-snapshots.log 取 SHA → git stash apply <sha>
# Snapshot 是 dangling commit，git gc 默认 30 天内不清。
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || true)
if [ -n "$GIT_DIR" ]; then
  SNAPSHOT_SHA=$(git stash create -u 2>/dev/null || true)
  if [ -n "$SNAPSHOT_SHA" ]; then
    LOG="$GIT_DIR/last-precommit-snapshots.log"
    BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
    echo "$(date -u +%FT%TZ) $SNAPSHOT_SHA $BRANCH" >> "$LOG"
    if [ -f "$LOG" ]; then
      tail -n 20 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
    fi
    echo "📸 工作树快照: $SNAPSHOT_SHA  (恢复: git stash apply $SNAPSHOT_SHA)"
  fi
fi

# 0.5 防止直接编辑 docs-site 生成副本（CLAUDE.md "Doc-site source-of-truth"）
# docs-site/docs/design/**/*.md 和 docs-site-design/docs/**/*.md 由 sync 脚本
# 从 docs/design/**/*.md 自动生成。直接改副本会被下一次 sync 静默覆盖且
# git status 看不到，定位极隐蔽。例外：index.md / .vitepress/（每个 site 自管）。
GENERATED_DOC_HITS=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '^(docs-site/docs/design/|docs-site-design/docs/)' \
  | grep -v -E '(^|/)index\.md$' \
  | grep -v -E '(^|/)\.vitepress/' \
  || true)
if [ -n "$GENERATED_DOC_HITS" ]; then
  echo ""
  echo "❌ 拒绝提交：以下文件是 docs-site 自动生成副本（不是源），直接编辑会被下一次 sync 覆盖："
  echo "$GENERATED_DOC_HITS" | sed 's/^/    /'
  echo ""
  echo "   源在 docs/design/<对应名>.md（git tracked）。同步脚本："
  echo "     • node docs-site/scripts/sync-design-docs.js"
  echo "     • node docs-site-design/scripts/sync-docs.js"
  echo ""
  echo "   修法：(1) 改源 docs/design/<对应名>.md；(2) 跑上面两个 sync 脚本刷新副本；"
  echo "        (3) 一并 git add 源 + 副本，再 commit。"
  echo ""
  echo "   例外白名单（已放行）：index.md / .vitepress/"
  echo "   绕过（自担风险）: git commit --no-verify"
  exit 1
fi

# 0.7 lint-staged sweep race 预警（trap #10）
# lint-staged 的 glob 在 worktree 含 untracked 文件时会 sweep 所有匹配文件，
# 包括对方 session 未 stage 的改动。配合 --no-stash 可能 silent 改写它们。
# 这里仅 warn 不 block — 用户/对端 session 可能就是想这样。
# 同时记下"非 staged 已 tracked-modified"文件的 SHA-256，供 post 步骤比对。
UNTRACKED_LIST=$(git status --porcelain | awk '/^\?\?/ {print $2}')
UNTRACKED_COUNT=$(echo -n "$UNTRACKED_LIST" | grep -c '^' 2>/dev/null || true)
UNSTAGED_TRACKED=$(git diff --name-only)
if [ -n "$UNTRACKED_LIST" ] || [ -n "$UNSTAGED_TRACKED" ]; then
  echo ""
  echo "⚠️  Worktree 不干净 (trap #10 lint-staged sweep)："
  [ -n "$UNTRACKED_LIST" ] && echo "    untracked (??): $UNTRACKED_COUNT 个 — lint-staged glob 会 sweep 进来"
  [ -n "$UNSTAGED_TRACKED" ] && echo "    unstaged tracked (.M/.D): 可能被 prettier/eslint silent 改格式"
  echo "    若另一 session 正改这些文件 → race 风险。建议 ctrl-c 先 git status 看清。"
  echo "    防御已自动：步骤 0 工作树快照（恢复见日志）"
fi
# 取一份 unstaged-tracked 文件的内容快照供 post 步骤 diff
PRE_LS_SNAP=""
if [ -n "$UNSTAGED_TRACKED" ]; then
  PRE_LS_SNAP=$(mktemp)
  while IFS= read -r f; do
    [ -f "$f" ] && printf '%s\t%s\n' "$(sha256sum "$f" 2>/dev/null | awk '{print $1}')" "$f"
  done <<< "$UNSTAGED_TRACKED" > "$PRE_LS_SNAP"
fi

# 1. 运行 lint-staged（ESLint + Prettier，仅针对暂存文件）
echo "📝 [1/2] 运行 ESLint 和代码格式化（仅暂存文件）..."
npx lint-staged --no-stash

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ ESLint 或格式化失败！请修复后重试。"
  echo "   跳过验证: git commit --no-verify"
  [ -n "$PRE_LS_SNAP" ] && rm -f "$PRE_LS_SNAP"
  exit 1
fi

echo "✅ ESLint 和代码格式化通过"

# 1.5 post-lint-staged sweep 受害者检测（trap #10）
# lint-staged 跑完后，比对 unstaged-tracked 文件 SHA。若变了 = lint-staged
# 改了用户没 stage 的文件 → 对方 session 的改动被 silent 改格式。
if [ -n "$PRE_LS_SNAP" ] && [ -f "$PRE_LS_SNAP" ]; then
  SWEEP_VICTIMS=""
  while IFS=$'\t' read -r old_sha f; do
    [ -z "$f" ] && continue
    [ ! -f "$f" ] && continue
    new_sha=$(sha256sum "$f" 2>/dev/null | awk '{print $1}')
    if [ "$old_sha" != "$new_sha" ]; then
      SWEEP_VICTIMS="${SWEEP_VICTIMS}    $f\n"
    fi
  done < "$PRE_LS_SNAP"
  rm -f "$PRE_LS_SNAP"
  if [ -n "$SWEEP_VICTIMS" ]; then
    echo ""
    echo "⚠️  lint-staged 改写了未 staged 的 tracked 文件 (trap #10 sweep 命中)："
    printf "$SWEEP_VICTIMS"
    echo "    这些改动不在你本次 commit 里，但工作树已变。"
    echo "    若你和对方 session 都在改，先核对 git diff 再继续。"
    echo "    恢复对方改动：tail .git/last-precommit-snapshots.log → git stash apply <sha>"
  fi
fi
echo ""

# 2. 运行 TypeScript 类型检查（仅暂存的 .ts/.vue 文件变更时）
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|vue)$' || true)
if [ -n "$STAGED_TS" ]; then
  echo "🔷 [2/2] 运行 TypeScript 类型检查..."
  node scripts/typecheck-staged.js

  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ TypeScript 类型检查失败！请修复后重试。"
    echo "   跳过验证: git commit --no-verify"
    exit 1
  fi

  echo "✅ TypeScript 类型检查通过"
else
  echo "🔷 [2/2] 无 TypeScript 文件变更，跳过类型检查"
fi

END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

echo ""
echo "✅ Pre-commit 检查通过！(${DURATION}s)"
echo ""
echo "💡 完整测试: cd desktop-app-vue && npm test"
echo "💡 规则验证: cd desktop-app-vue && npm run validate:rules"

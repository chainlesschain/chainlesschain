echo "📤 Auto push to github (--no-verify, skip vue-tsc)..."
echo ""

# Auto push installed 2026-05-12. Dual-pushed to github + gitee since
# 2026-05-28 (gitee was dropped 2026-05-26 because local .git 1325MB exceeded
# gitee 1GB quota; re-added after the .git slim operation 2026-05-28 brought
# pack size to ~1.97 GiB with HEAD-reachable closure well under 1 GB — see
# git_slim_2026_05_28_recipe memory entry).
# - Pre-push hook runs vue-tsc (~30s). Auto-push uses --no-verify to skip it
#   per user pref — type-checking still runs in CI (test-automation-full.yml /
#   pr-tests.yml). Manual `git push` without --no-verify still triggers vue-tsc.
# - Skip remote 'github-https' (HTTPS mirror of github SSH) — same content,
#   redundant push.
# - Failures print loud WARN but don't roll back the commit (post-commit can't
#   anyway). Retry the failing push manually with `git push <remote> <branch>`.
#
# Disable: chmod -x .husky/post-commit  OR  mv .husky/post-commit .husky/post-commit.disabled

set +e

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || branch=main

# Detect amend/rewrite (push will be rejected non-fast-forward)
amended=""
if git rev-parse --verify HEAD@{1} >/dev/null 2>&1; then
  if ! git merge-base --is-ancestor HEAD@{1} HEAD 2>/dev/null; then
    amended=" (looks amended/rewritten — push may need --force-with-lease)"
  fi
fi

echo "[post-commit] $branch${amended}"

for remote in github gitee; do
  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    echo "[post-commit] (skip $remote: remote not configured)"
    continue
  fi
  # --no-verify skips the pre-push vue-tsc check (~30s). Type checking still
  # runs in CI on every push to remote.
  if out=$(git push --no-verify "$remote" "$branch" 2>&1); then
    summary=$(echo "$out" | grep -E '(\.\.|new branch|new tag)' | tail -1)
    echo "[post-commit] OK $remote: ${summary:-pushed}"
  else
    echo "[post-commit] WARN $remote push FAILED:" >&2
    echo "$out" | tail -5 >&2
    echo "[post-commit]   retry manually: git push $remote $branch" >&2
  fi
done

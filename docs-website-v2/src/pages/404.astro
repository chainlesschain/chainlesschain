---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="页面未找到 — ChainlessChain" canonical="https://www.chainlesschain.com/404">
  <section class="min-h-[60vh] flex items-center">
    <div class="container-wide text-center">
      <div class="font-mono text-xs text-ember mb-4">HTTP 404</div>
      <h1 class="font-display text-display-xl leading-none mb-6">走丢了。</h1>
      <p class="text-muted text-xl mb-10">这个路径不在我们的地图里 — 但你可以回到起点。</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn-ember">返回首页 →</a>
        <a href="/cli" class="btn-ghost">查看 CLI 命令</a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import rootPkg from '../../../package.json';
import cliPkg from '../../../packages/cli/package.json';
import releaseSizes from '../data/release-sizes.json';

const PRODUCT_VERSION = rootPkg.productVersion;
// Published npm CLI version (release-sizes.json, pinned at build by
// fetch-release-sizes.mjs from npm's `latest` dist-tag). Falls back to the
// in-repo package.json only if the registry fetch + cache both failed — that
// fallback can drift ahead of npm during dev, so the pinned value is the norm.
const CLI_VERSION = releaseSizes.cliVersion || cliPkg.version;
const ANDROID_TAG = releaseSizes.tag || PRODUCT_VERSION;
const ANDROID_VERSION = ANDROID_TAG;
const ANDROID_RELEASE_URL = `https://github.com/chainlesschain/chainlesschain/releases/tag/${ANDROID_TAG}`;
const androidArm64 = releaseSizes.sizes['android-arm64-v8a'];
const androidUniversal = releaseSizes.sizes['android-universal'];

const templates = [
  { id: 'doc-convert', name: '文档格式转换', tools: 'pandoc · LibreOffice' },
  { id: 'media-process', name: '音视频处理', tools: 'ffmpeg · yt-dlp' },
  { id: 'data-analysis', name: '数据分析', tools: 'pandas · matplotlib' },
  { id: 'web-research', name: '信息检索与调研', tools: 'curl · BeautifulSoup' },
  { id: 'image-process', name: '图片处理', tools: 'ImageMagick · Tesseract' },
  { id: 'code-helper', name: '代码辅助', tools: 'Python · Node.js' },
  { id: 'system-admin', name: '系统运维', tools: '系统命令' },
  { id: 'file-organize', name: '文件整理', tools: 'pathlib · 7-Zip' },
  { id: 'network-tools', name: '网络工具', tools: 'curl · nslookup' },
];

// 三大核心能力（产品定位主线）
const pillars = [
  {
    icon: '📚',
    title: '知识库管理',
    en: 'Knowledge Base',
    bullets: [
      '笔记 / 文档 / 对话历史 — 个人第二大脑',
      '混合搜索：BM25 + Qdrant 向量',
      '层级记忆 2.0：工作 → 短期 → 长期 → 核心',
      '基于 RAG 的 AI 问答 · 代码知识图谱',
    ],
  },
  {
    icon: '🌐',
    title: '去中心化社交',
    en: 'Decentralized Social',
    bullets: [
      'W3C DID v2 身份 + 可验证凭证',
      'P2P 端到端加密：Signal + libp2p + WebRTC',
      '社区 / 频道 gossip 跨机同步（v5.0.3.41+）',
      'Audit-grade Merkle envelope + 跨机分发 + 外部归档（B4 全套）',
      '协议融合：ActivityPub · Nostr · Matrix',
      '反审查：Tor + 域前置 + 卫星消息',
    ],
  },
  {
    icon: '💎',
    title: '数字资产交易',
    en: 'Trading Assistant',
    bullets: [
      '多链钱包：EVM 系 + Solana',
      '跨链桥：HTLC 原子交换 + 跨链消息',
      'zk-SNARK / zk-STARK 本地生成',
      'DAO 治理 v2 · 二次方投票 · 国库管理',
    ],
  },
];

// 普通人卡片（Web Cowork 能做什么）
const everyday = [
  { icon: '📄', title: '文档转换', example: '批量把 Word 转 PDF / Word 转 Markdown' },
  { icon: '🎬', title: '媒体处理', example: '视频压缩、提取音频、格式转换' },
  { icon: '📊', title: '数据分析', example: 'CSV / Excel 分析 + 生成图表' },
  { icon: '🖼️', title: '图片处理', example: '批量压缩、OCR 识别文字' },
  { icon: '🔎', title: '信息检索', example: '自动搜索 + 整理结果' },
  { icon: '🧰', title: '系统管理', example: '磁盘分析、进程排查、网络测试' },
];

const badges = [
  { icon: '🏆', label: '4 项发明专利' },
  { icon: '🔒', label: '军事级加密' },
  { icon: '⭐', label: 'Open VSX 插件安装破万' },
  { icon: '✅', label: '等保三级认证' },
  { icon: '📋', label: '参编《人工智能 智能体内生安全技术要求》T/ZGCMCA 023—2025', href: 'https://www.ttbz.org.cn/standardDetail.html?id=jy42azxbb1ymwtf6tm371ejs6jcuwz7' },
];
---
<BaseLayout>
  <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-paper opacity-60 pointer-events-none"></div>
    <div class="absolute top-20 right-0 w-[500px] h-[500px] rounded-full bg-ember/10 blur-3xl pointer-events-none"></div>
    <div class="container-wide relative pt-20 pb-24 md:pt-28 md:pb-32">
      <div class="max-w-4xl">
        <div class="animate-fade-in flex items-center gap-3 mb-8 flex-wrap">
          <span class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> {PRODUCT_VERSION} · Evolution Edition</span>
          <span class="chip">CLI v{CLI_VERSION}</span>
          <span class="chip">173 命令</span>
          <a href="https://open-vsx.org/extension/chainlesschain/chainlesschain-ide" target="_blank" rel="noopener" class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> 🎉 VS Code 插件 Open VSX 安装破万</a>
          <a href="https://www.npmjs.com/package/chainlesschain" target="_blank" rel="noopener" class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> 📦 CLI npm 月下载 2.2 万+</a>
          <span class="chip">Web Shell（默认）</span>
          <span class="chip">Web Panel i18n（中英）</span>
          <span class="chip">MTC v0.11</span>
        </div>

        <h1 class="animate-fade-in-delay font-display text-6xl md:text-display-lg leading-[1.02] tracking-tight">
          让数据主权<br/>
          <span class="italic">回归个人</span>，<br/>
          AI 效率<span class="text-ember italic">触手可及</span>。
        </h1>

        <p class="animate-fade-in-delay-2 mt-8 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl">
          CLI 驱动的本地 AI × 硬件级加密。<br class="hidden md:block"/>
          为每一个想掌控自己数据的人而建。
        </p>

        <div class="animate-fade-in-delay-3 mt-10 flex flex-wrap items-center gap-4">
          <button
            class="btn-primary group"
            data-copy="npm i -g chainlesschain"
            aria-label="复制安装命令"
          >
            <span class="text-ember">$</span>
            <span>npm i -g chainlesschain</span>
            <span class="text-muted-dark text-xs ml-2 group-hover:text-cream">点击复制</span>
          </button>
          <a href="#security" class="btn-ghost">
            了解硬件加密 <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Trust badges -->
        <div class="animate-fade-in-delay-3 mt-14 pt-8 border-t border-line flex flex-wrap gap-x-8 gap-y-3">
          {badges.map((b) => (
            b.href ? (
              <a href={b.href} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </a>
            ) : (
              <div class="flex items-center gap-2 text-sm text-muted">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </div>
            )
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ 三大核心能力 ═══════════════════════════════ -->
  <section class="py-20 md:py-28 border-b border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-14">
        <div class="chip mb-6">产品定位 · 三大场景</div>
        <h2 class="text-display-md md:text-5xl leading-tight">
          知识 · 社交 · 交易，<br/>
          <span class="italic text-ember">以个人为中心，全栈端到端</span>。
        </h2>
        <p class="mt-6 text-xl text-muted leading-relaxed">
          一套硬件级安全 + 本地化 AI + 完全去中心化的共同基座，三大场景独立可用、互通无界。
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {pillars.map((p) => (
          <div class="p-8 rounded-2xl border border-line bg-paper hover:border-ember hover:-translate-y-0.5 transition-all">
            <div class="text-3xl mb-4">{p.icon}</div>
            <h3 class="font-display text-2xl mb-1">{p.title}</h3>
            <div class="font-mono text-[10px] text-muted uppercase tracking-widest mb-5">{p.en}</div>
            <ul class="space-y-2 text-sm text-ink/80">
              {p.bullets.map((b) => (
                <li class="flex gap-2"><span class="text-ember shrink-0">·</span><span>{b}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-10 grid md:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">隐私至上</div>
          <div class="text-sm text-ink/80">端到端加密 · 硬件级安全 · 零知识证明 — 服务方无法访问用户数据。</div>
        </div>
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">完全去中心化</div>
          <div class="text-sm text-ink/80">本地数据存储（SQLCipher AES-256）· P2P 通信（libp2p）· 自主掌控（DID v2）。</div>
        </div>
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">AI 原生</div>
          <div class="text-sm text-ink/80">本地大模型（Ollama / LLaMA / Qwen）· 默认不上传 prompt · AI 增强搜索 + Agent 编排。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ 个人数据中台（Personal Data Hub）═══════════════════════════════ -->
  <section class="py-24 md:py-32 bg-ink text-cream relative overflow-hidden">
    <!-- 装饰底纹 -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 w-72 h-72 rounded-full bg-ember blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full bg-ember blur-3xl"></div>
    </div>

    <div class="container-wide relative">
      <div class="max-w-4xl mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-ember/15 border border-ember/30 mb-6">
          <span class="w-1.5 h-1.5 bg-ember rounded-full animate-pulse"></span>
          <span class="font-mono text-[11px] text-ember uppercase tracking-widest">个人数据中台 · v5.0.3.134 · 50+ 数据源真机生效</span>
        </div>
        <h2 class="text-display-md md:text-5xl leading-tight font-display">
          把散落各处的数字足迹，<br/>
          <span class="italic text-ember">汇成一份只属于你的金库。</span>
        </h2>
        <p class="mt-6 text-xl md:text-2xl text-cream/80 leading-relaxed">
          邮件 · 微信 · 支付宝 · 9 家 AI Chat · 社交平台 · 电商 · 旅行 · 健康 · 音乐 · 阅读 · 电脑版 IM · Android 系统数据 ——<br class="hidden md:block"/>
          <span class="text-cream">50+ 数据源端到端拉回本地</span>，谁也拿不走。
        </p>
        <p class="mt-5 text-base text-cream/60 italic max-w-2xl">
          "让数据主权回归个人" 不是口号 —— 是 51 个真接通的适配器、5 个内置分析技能、1 份本地加密金库。
        </p>
      </div>

      <!-- 5-grid 数据源分类 -->
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4 mb-12">
        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">📧</div>
          <div class="font-display text-lg mb-2">邮件 / 账单</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· IMAP 全协议 邮箱</li>
            <li>· 支付宝账单 CSV / PDF</li>
            <li>· 6 模板抽取（账单/订单/出行）</li>
            <li>· PDF 解密 + 交易明细</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🤖</div>
          <div class="font-display text-lg mb-2">AI Chat 历史</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· DeepSeek · Kimi · 通义</li>
            <li>· 智谱 · 混元 · 千帆</li>
            <li>· 扣子 · Dreamina · 豆包</li>
            <li class="text-ember/80 font-mono text-[10px] pt-1">9 / 9 全接通</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">💬</div>
          <div class="font-display text-lg mb-2">社交平台</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· 微信（SQLCipher · MD5 + Frida 双路径）</li>
            <li>· QQ · 微博 · B 站</li>
            <li>· 抖音 · 小红书</li>
            <li>· Telegram · WhatsApp</li>
            <li>· 电脑版直读：微信PC · QQ-NT · 钉钉 · 飞书</li>
            <li class="text-ember/80 font-mono text-[10px] pt-1">免密钥一键采集 · 电脑版 IM 本地直读</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🛍️</div>
          <div class="font-display text-lg mb-2">消费 / 出行</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· 淘宝 · 京东 · 美团</li>
            <li>· 高德 · 百度地图</li>
            <li>· 携程 · 12306</li>
            <li>· 订单/物流/足迹聚合</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">📱</div>
          <div class="font-display text-lg mb-2">系统数据</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· 通讯录 · 通话记录</li>
            <li>· 短信 · 位置历史</li>
            <li>· Android ADB 备份</li>
            <li>· iOS 加密备份解密</li>
            <li>· Apple 健康 · 网易云音乐 · 微信读书</li>
            <li class="text-ember/80 font-mono text-[10px] pt-1">+ 开发者本机活动 7 件套（git/vscode/shell/浏览器…）</li>
          </ul>
        </div>
      </div>

      <!-- 3-feature 下沉条 -->
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">本地金库</div>
          <div class="text-sm text-cream/85 leading-relaxed">SQLCipher AES-256 加密落盘，数据从不上传云端 —— 邮件密码、聊天密钥、账单金额，全在你的设备里。</div>
        </div>
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">5 个内置分析技能</div>
          <div class="text-sm text-cream/85 leading-relaxed">消费趋势 · 出行画像 · 沟通频率 · 内容偏好 · 时间分布 —— LLM 直接调，问"我去年在哪三家店花得最多"立刻有答案。</div>
        </div>
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">实体归一化（EntityResolver）</div>
          <div class="text-sm text-cream/85 leading-relaxed">"张三" / "Zhang San" / "+86 138-xxxx" 自动认成同一人 —— 跨邮件/微信/通讯录的关系图谱真接得起来。</div>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap gap-3 items-center">
        <a href="https://docs.chainlesschain.com/chainlesschain/personal-data-hub.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-ember text-ink font-medium hover:bg-ember/90 transition-colors">
          完整功能介绍 →
        </a>
        <a href="https://design.chainlesschain.com/Personal_Data_Hub_Architecture.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-cream/20 text-cream/80 hover:border-ember hover:text-cream transition-all">
          架构设计文档 ↗
        </a>
        <span class="text-xs font-mono text-cream/40 ml-2">出行/购物/社交/文档/音乐/视频/招聘全覆盖 · 9 / 9 AIChat vendor 真接通 · WeChat MD5+Frida 双路径 · 电脑版 IM 本地直读 · pdh npm 0.4.50</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ 去中心化社交（Decentralized Social）═══════════════════════════════ -->
  <section class="py-24 md:py-32 bg-cream/40 border-y border-line relative overflow-hidden">
    <div class="container-wide relative">
      <div class="max-w-4xl mb-16">
        <div class="chip mb-6">三大核心 · 去中心化社交</div>
        <h2 class="text-display-md md:text-5xl leading-tight font-display">
          加好友、发消息、发动态 ——<br/>
          <span class="italic text-ember">没有平台居中。</span>
        </h2>
        <p class="mt-6 text-xl md:text-2xl text-muted leading-relaxed">
          身份是你自己的 DID，消息点对点端到端加密，社区跨机同步 ——<br class="hidden md:block"/>
          <span class="text-ink">没人能封你的号、删你的帖、看你的私信。</span>
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🪪</div>
          <div class="font-display text-lg mb-2">自主身份 DID v2</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· W3C DID + 可验证凭证 VC / VP</li>
            <li>· 社交恢复 + 跨设备漫游</li>
            <li>· 信誉聚合，无需中心账号体系</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🔒</div>
          <div class="font-display text-lg mb-2">端到端加密消息</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· Signal 协议 + libp2p + WebRTC</li>
            <li>· 密钥只在两端，服务器看不到明文</li>
            <li>· 离线互加 + 信令中继兜底</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">📞</div>
          <div class="font-display text-lg mb-2">好友语音 / 视频通话</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· WebRTC 直连，毫秒级建连</li>
            <li>· 锁屏全屏来电 + 前台保活</li>
            <li>· 通话历史本地落库</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🌐</div>
          <div class="font-display text-lg mb-2">社区 / 频道 跨机同步</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· gossip 跨节点分发</li>
            <li>· Audit-grade Merkle 信封</li>
            <li>· 外部归档，断网也不丢</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🔗</div>
          <div class="font-display text-lg mb-2">协议融合互通</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· ActivityPub C2S 联邦</li>
            <li>· Nostr NIP-01/04/09/25</li>
            <li>· Matrix 线程 & 空间</li>
          </ul>
        </div>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';

const templates = [
  { id: 'doc-convert', name: '文档格式转换', tools: 'pandoc · LibreOffice' },
  { id: 'media-process', name: '音视频处理', tools: 'ffmpeg · yt-dlp' },
  { id: 'data-analysis', name: '数据分析', tools: 'pandas · matplotlib' },
  { id: 'web-research', name: '信息检索与调研', tools: 'curl · BeautifulSoup' },
  { id: 'image-process', name: '图片处理', tools: 'ImageMagick · Tesseract' },
  { id: 'code-helper', name: '代码辅助', tools: 'Python · Node.js' },
  { id: 'system-admin', name: '系统运维', tools: '系统命令' },
  { id: 'file-organize', name: '文件整理', tools: 'pathlib · 7-Zip' },
  { id: 'network-tools', name: '网络工具', tools: 'curl · nslookup' },
];

// 普通人卡片（Web Cowork 能做什么）
const everyday = [
  { icon: '📄', title: '文档转换', example: '批量把 Word 转 PDF / Word 转 Markdown' },
  { icon: '🎬', title: '媒体处理', example: '视频压缩、提取音频、格式转换' },
  { icon: '📊', title: '数据分析', example: 'CSV / Excel 分析 + 生成图表' },
  { icon: '🖼️', title: '图片处理', example: '批量压缩、OCR 识别文字' },
  { icon: '🔎', title: '信息检索', example: '自动搜索 + 整理结果' },
  { icon: '🧰', title: '系统管理', example: '磁盘分析、进程排查、网络测试' },
];

const evolution = [
  // ── v5.0.2.9 Evolution ──
  { tag: 'v5.0.2.9', title: 'Hashline', sub: '内容哈希锚定编辑', desc: '用 6 字符哈希替代行号锚点，抗自动格式化漂移，成功率从 6.7% 跃升至 68.3%。' },
  { tag: 'v5.0.2.9', title: 'Hooks 三件套', sub: '会话级生命周期钩子', desc: 'SessionStart / UserPromptSubmit / SessionEnd 三个生命周期点统一触发，fire-and-forget 零侵入。' },
  { tag: 'v5.0.2.9', title: 'Skill-Embedded MCP', sub: '技能内联 MCP 服务器', desc: 'SKILL.md 内用 fenced code block 声明 MCP 服务器，按需 mount/unmount，解决工具爆炸问题。' },
  { tag: 'v5.0.2.9', title: 'Category Routing', sub: '类别路由替代硬编码模型', desc: 'quick / deep / reasoning / vision / creative 五类别自动匹配已配置 provider，换模型零代码改动。' },
  { tag: 'v5.0.2.9', title: 'Sub-Runtime Pool', sub: '子运行时池', desc: 'Electron 主进程 spawn 子进程，sessionId 分片避免冲突，stdio JSON-lines 协议。' },
  { tag: 'v5.0.2.9', title: 'Canonical Workflow', sub: '标准化工作流编排', desc: '统一工作流描述语法，stage 间自动传递数据，支持串行 / 并行 / DAG 拓扑。' },
  { tag: 'v5.0.2.9', title: 'Unified Tool Descriptor', sub: '工具描述规范统一', desc: 'inputSchema 为真源，parameters 只读镜像。CLI / Desktop / Renderer / MCP 四端字段对齐。' },
  { tag: 'v5.0.2.9', title: 'Coding Agent Envelope', sub: 'WebSocket 信封协议', desc: 'dot-case 类型 + requestId 关联，bridge unwrap 双 awaitTypes 支持平滑迁移。' },
  { tag: 'v5.0.2.9', title: 'Autonomous Learning Loop', sub: '自主学习循环', desc: '从执行历史中自动提炼模式、优化提示词与工具选择策略，越用越懂你。' },

  // ── v5.0.2.10 / v5.0.2.30 Evolution ──
  { tag: 'v5.0.2.10', title: '去中心化社交协议矩阵', sub: 'Nostr + Matrix + ActivityPub', desc: 'NIP-04/09/25 + Matrix Threads/Spaces + ActivityPub C2S，加好友、发帖、回复与点赞跨协议互通。' },
  { tag: 'v5.0.2.10', title: 'STIX 2.1 + UEBA', sub: '威胁情报与合规报告', desc: '导入/匹配 IoC、实体行为基线、SOC2 / ISO27001 / GDPR 模板化报告，一条命令生成 MD/HTML/JSON。' },
  { tag: 'v5.0.2.10', title: 'MCP Scaffold + 社区注册中心', sub: '零成本扩展 MCP 生态', desc: '`mcp scaffold` 生成 stdio / HTTP+SSE 骨架；`mcp registry` 浏览、搜索、安装社区服务器。' },
  { tag: 'v5.0.2.10', title: 'MCP Streamable HTTP/SSE', sub: '远程 MCP 服务器接入', desc: '`mcp add -u <url>` 直连远程服务器，自动 Mcp-Session-Id + SSE 事件流解析，私有请求头可注入。' },
  { tag: 'v5.0.2.10', title: 'PQC SLH-DSA (FIPS 205)', sub: '6 个无状态哈希签名参数集', desc: 'SLH-DSA-{128,192,256}{s,f} 全部落地 + Ed25519/X25519 混合模式，过渡期双重安全保障。' },
  { tag: 'v5.0.2.10', title: 'Managed Agents Phase I+J', sub: '托管 Agent 双向打通', desc: 'session tail / usage 回放 + WS sessions.subscribe + hosted-tool ApprovalGate + auto-consolidate。' },
  { tag: 'v5.0.2.10', title: 'CutClaw 视频剪辑 Agent', sub: 'AI 端到端视频生产', desc: 'deconstruct → plan → assemble → render，--parallel 质量门控 + madmom beat-snap + 音频 ducking。' },
  { tag: 'v5.0.2.10', title: '通用 QualityGate', sub: '可插拔质量检查器', desc: '加权平均 / 最低分 / 全通过三种聚合，配合 SubRuntimePool 的 detect→score→rerun 冲突解决流程。' },
  { tag: 'v5.0.2.10', title: '生产强化 Deploy Check', sub: 'config-check + deploy-check', desc: '真实配置扫描 + CI 部署前全链路预检：端口、证书、磁盘、迁移、PQC 密钥、MCP 联通。' },

  // ── v5.0.2.10 Phase 59-66 + 94/97/48/54 CLI Ports ──
  { tag: 'v5.0.2.10', title: '自主开发者系统', sub: 'Phase 63 Autonomous Developer', desc: 'L0-L4 自治等级 + 开发会话生命周期 + ADR 架构决策记录 + 代码反模式检测 review。' },
  { tag: 'v5.0.2.10', title: '协作治理引擎', sub: 'Phase 64 Collaboration Governance', desc: '治理决策提案→投票→裁定→执行，Agent 自治级别管控，技能匹配与任务分配优化。' },
  { tag: 'v5.0.2.10', title: '技能市场', sub: 'Phase 65 Skill Marketplace', desc: '发布/订阅技能服务，调用计量 + 统计面板，版本管理与定价策略。' },
  { tag: 'v5.0.2.10', title: '代币激励系统', sub: 'Phase 66 Token Incentive', desc: 'Token 账本 mint/transfer/balance + 7 种贡献类型自动奖励 + 排行榜。' },
  { tag: 'v5.0.2.10', title: '企业知识图谱', sub: 'Phase 94 Knowledge Graph', desc: '实体/关系 CRUD + BFS 多跳推理 + 图密度分析 + JSON 导入导出。' },
  { tag: 'v5.0.2.10', title: '多租户 SaaS 引擎', sub: 'Phase 97 Multi-Tenant', desc: '4 档订阅 (free/starter/pro/enterprise) + 用量计量 + 配额检查 + 快照导入导出。' },
  { tag: 'v5.0.2.10', title: '智能推荐系统', sub: 'Phase 48 Content Recommendation', desc: '兴趣画像 + 内容评分 + 反馈回路 + 时间衰减，17 个子命令覆盖全流程。' },
  { tag: 'v5.0.2.10', title: '社区治理', sub: 'Phase 54 AI Community Governance', desc: '提案生命周期 + 加权投票 + 影响分析 + 预测置信度，去中心化社区自治。' },
  { tag: 'v5.0.2.10', title: '代码生成 Agent 2.0', sub: 'Phase 86 Code Generation', desc: '14 子命令覆盖生成/审查/脚手架全流程，5 种安全规则 + 3 CI/CD 平台集成。' },
  { tag: 'v5.0.2.10', title: '数据库演进框架', sub: 'Phase 80 Database Evolution', desc: '迁移注册/执行/回滚 + 慢查询日志 + 索引建议自动生成与应用。' },
  { tag: 'v5.0.2.10', title: 'AIOps 智能运维', sub: 'Phase 25 Autonomous Ops', desc: '指标基线 + Z-score/IQR 异常检测 + 事件生命周期 + Playbook 自动修复 + 事后复盘。' },

  // ── v5.0.2.10 Phase 17/20/27/28/58/63/84 CLI Ports ──
  { tag: 'v5.0.2.10', title: '多模态感知引擎', sub: 'Phase 84 Multimodal Perception', desc: '感知结果记录 + 语音会话状态机 + 跨模态索引 + 多维度查询与上下文聚合。' },
  { tag: 'v5.0.2.10', title: '联邦网络硬化', sub: 'Phase 58 Federation Hardening', desc: '断路器状态机（closed→open→half-open）+ 节点健康检查 + 连接池管理。' },
  { tag: 'v5.0.2.10', title: '自然语言编程', sub: 'Phase 28 NL Programming', desc: '意图分类 + 实体提取 + 技术栈检测 + NL→结构化规格翻译 + 项目编码约定管理。' },
  { tag: 'v5.0.2.10', title: '模型量化系统', sub: 'Phase 20 Model Quantization', desc: 'GGUF 14 级量化 + GPTQ 多位宽 + 量化任务全生命周期（create→start→complete/fail/cancel）。' },
  { tag: 'v5.0.2.10', title: '统一应用运行时', sub: 'Phase 63 Universal Runtime', desc: '插件热加载/卸载 + semver 热更新与回滚 + LWW 状态同步 + 运行时 profiling。' },
  { tag: 'v5.0.2.10', title: 'IPFS 去中心化存储', sub: 'Phase 17 IPFS Storage', desc: '模拟 CID + AES-256-GCM 加密 + Pin 管理 + 配额/GC + 知识库附件关联。' },
  { tag: 'v5.0.2.10', title: '多模态协作', sub: 'Phase 27 Multimodal Collaboration', desc: '5 种模态加权融合 + 7 种文档原生解析 + 4000-token 上下文 + 6 种输出格式。' },

  // ── v5.0.2.10 Phase 14/22/24/26/55/64/96 + V2 增强 ──
  { tag: 'v5.0.2.10', title: '去中心化 Agent 网络', sub: 'Phase 24 Agent Network', desc: 'Ed25519 DID + Kademlia 发现 + challenge-response 认证 + W3C VC 凭证 + 4 维信誉任务路由。' },
  { tag: 'v5.0.2.10', title: '工作流自动化引擎', sub: 'Phase 96 Automation Engine', desc: '12 SaaS 连接器 + webhook/schedule 触发器 + DAG 拓扑排序 + 条件分支执行。' },
  { tag: 'v5.0.2.10', title: '去中心化身份 2.0', sub: 'Phase 55 DID v2', desc: 'did:key/web/chain + VC/VP 签发验证 + k-of-n 社交恢复 + 身份漫游 + 多源信誉聚合。' },
  { tag: 'v5.0.2.10', title: '性能自动调优', sub: 'Phase 22 Performance Tuning', desc: '实时 OS 采样 + 5 条迟滞规则 + 冷却时间 + 调优建议生成与应用。' },
  { tag: 'v5.0.2.10', title: '开发流水线编排', sub: 'Phase 26 Pipeline Orchestration', desc: '7 阶段流水线 + 4 模板 + 6 部署策略 + 双门审批 + 制品管理 + 监控。' },
  { tag: 'v5.0.2.10', title: '智能插件生态 2.0', sub: 'Phase 64 Plugin Ecosystem', desc: 'DFS 依赖解析 + 8 规则 AI 审查 + 沙箱测试 + 审核发布 + 70/30 收益分成。' },
  { tag: 'v5.0.2.10', title: 'SSO 企业认证', sub: 'Phase 14 SSO Authentication', desc: 'SAML/OAuth2/OIDC + PKCE S256 + AES-256-GCM 令牌加密 + DID 身份桥接。' },
  { tag: 'v5.0.2.10', title: 'V2 增强套件（第一批）', sub: '8 模块 V2 升级', desc: 'DAO 治理/经济/进化/记忆/沙箱/工作流/ZKP/社交图分析 — 全面升级到 V2 规范表面。' },
  { tag: 'v5.0.2.10', title: 'V2 增强套件（第二批）', sub: '14 模块 V2 升级', desc: 'A2A/BI/跨链/DLP/EvoMap/推理/低代码/市场/隐私/信誉/SIEM/SLA/压测/Terraform — 3800+ 行 V2 规范 API。' },
  { tag: 'v5.0.2.10', title: 'V2 增强套件（第三批）', sub: '11 模块 V2 升级', desc: 'ZKP/联邦/审计/合规/加固/激励/知识图谱/运维/插件生态/租户 — 全 CLI 命令 V2 规范化完成。' },
];

const badges = [
  { icon: '🏆', label: '4 项发明专利' },
  { icon: '🔒', label: '军事级加密' },
  { icon: '⭐', label: 'GitHub 10k+ Star' },
  { icon: '✅', label: '等保三级认证' },
  { icon: '📋', label: 'T/ZGCMCA 023—2025 参编' },
];
---
<BaseLayout>
  <!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-paper opacity-60 pointer-events-none"></div>
    <div class="absolute top-20 right-0 w-[500px] h-[500px] rounded-full bg-ember/10 blur-3xl pointer-events-none"></div>
    <div class="container-wide relative pt-20 pb-24 md:pt-28 md:pb-32">
      <div class="max-w-4xl">
        <div class="animate-fade-in flex items-center gap-3 mb-8">
          <span class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> v5.0.2.10 · Evolution Edition</span>
          <span class="chip">CLI v0.90.0</span>
        </div>

        <h1 class="animate-fade-in-delay font-display text-6xl md:text-display-lg leading-[1.02] tracking-tight">
          让数据主权<br/>
          <span class="italic">回归个人</span>，<br/>
          AI 效率<span class="text-ember italic">触手可及</span>。
        </h1>

        <p class="animate-fade-in-delay-2 mt-8 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl">
          CLI 驱动的本地 AI × 硬件级加密。<br class="hidden md:block"/>
          为每一个想掌控自己数据的人而建。
        </p>

        <div class="animate-fade-in-delay-3 mt-10 flex flex-wrap items-center gap-4">
          <button
            class="btn-primary group"
            data-copy="npm i -g chainlesschain"
            aria-label="复制安装命令"
          >
            <span class="text-ember">$</span>
            <span>npm i -g chainlesschain</span>
            <span class="text-muted-dark text-xs ml-2 group-hover:text-cream">点击复制</span>
          </button>
          <a href="#security" class="btn-ghost">
            了解硬件加密 <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Trust badges -->
        <div class="animate-fade-in-delay-3 mt-14 pt-8 border-t border-line flex flex-wrap gap-x-8 gap-y-3">
          {badges.map((b) => (
            <div class="flex items-center gap-2 text-sm text-muted">
              <span class="text-base">{b.icon}</span>
              <span>{b.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ CLI ═══════════════════════════════ -->
  <section class="py-24 md:py-32">
    <div class="container-wide grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div>
        <div class="chip mb-6">CLI · 主入口</div>
        <h2 class="text-display-md md:text-5xl mb-6">
          你的终端，<br/>就是 AI 工作台。
        </h2>
        <p class="prose-muted text-lg mb-8">
          无需启动任何 GUI — <code class="font-mono text-sm bg-cream px-2 py-0.5 rounded">chainlesschain</code> 让本地 AI、Agent 编码、多智能体协作全部在终端里完成。
        </p>
        <div class="grid grid-cols-3 gap-6 mb-8">
          <div>
            <div class="font-display text-4xl text-ember">76</div>
            <div class="text-sm text-muted mt-1">CLI 命令</div>
          </div>
          <div>
            <div class="font-display text-4xl text-ember">139</div>
            <div class="text-sm text-muted mt-1">内置 Skills</div>
          </div>
          <div>
            <div class="font-display text-4xl text-ember">5517+</div>
            <div class="text-sm text-muted mt-1">测试用例</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="/cli" class="btn-ember">查看所有命令 →</a>
          <a href="https://docs.chainlesschain.com" rel="noopener" class="btn-ghost">CLI 文档 ↗</a>
        </div>
      </div>
      <div class="md:pl-4">
        <Terminal />
        <div class="mt-4 text-xs text-muted font-mono text-center">Agent / Cowork / Skill — 终端里的完整 AI 工作流</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ 普通人能做什么 ═══════════════════════════════ -->
  <section class="py-24 md:py-32 bg-cream/50 border-y border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-14">
        <div class="chip mb-6">普通人 · 零门槛 AI 工具箱</div>
        <h2 class="text-display-md md:text-5xl leading-tight">
          对 AI 说人话，<br/>
          <span class="italic text-ember">它替你干活</span>。
        </h2>
        <p class="mt-6 text-xl text-muted leading-relaxed">
          不用背命令、不用写代码。打开 Web 控制台，告诉它你想做什么 —<br class="hidden md:block"/>
          Agent 自动挑工具、自动装依赖、实时流式回报进度。
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {everyday.map((e) => (
          <div class="group p-7 rounded-2xl border border-line bg-paper hover:border-ember hover:-translate-y-0.5 transition-all">
            <div class="text-3xl mb-4">{e.icon}</div>
            <h3 class="font-display text-xl mb-2 group-hover:text-ember transition-colors">{e.title}</h3>
            <p class="text-sm text-muted leading-relaxed mb-4">{e.example}</p>
            <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-ember/10 text-ember text-[11px] font-mono">
              <span class="w-1 h-1 bg-ember rounded-full"></span> 自动安装所需工具，无需手动配置
            </div>
          </div>
        ))}
      </div>

      <!-- Web Cowork screenshot -->
      <figure class="mt-10 border border-ink/10 rounded-xl overflow-hidden shadow-xl bg-paper">
        <img
          src="/screenshots/cowork.png"
          alt="Web Cowork 日常协作界面 · 10 个任务模板"
          width="1400"
          height="900"
          loading="lazy"
          class="block w-full h-auto"
        />
      </figure>
      <p class="mt-3 text-center text-xs text-muted">运行 <code class="font-mono bg-cream px-2 py-0.5 rounded">chainlesschain ui</code>，浏览器打开 <code class="font-mono bg-cream px-2 py-0.5 rounded">http://localhost:18810/#/cowork</code></p>

      <div class="mt-10 grid md:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl bg-paper border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">零安装工作流</div>
          <div class="text-sm text-ink/80">Agent 自动 winget / choco / pip / npm 装工具，不用你配环境。</div>
        </div>
        <div class="p-5 rounded-xl bg-paper border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">安全隔离执行</div>
          <div class="text-sm text-ink/80">SubAgentContext 沙箱隔离，每个任务独立上下文，互不污染。</div>
        </div>
        <div class="p-5 rounded-xl bg-paper border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">实时进度</div>
          <div class="text-sm text-ink/80">WebSocket 流式返回每一步结果，不是"黑盒跑完才告诉你"。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ SECURITY (dark) ═══════════════════════════════ -->
  <section id="security" class="relative bg-ink text-cream py-24 md:py-32">
    <div class="absolute inset-0 bg-grid-ink opacity-50 pointer-events-none"></div>
    <div class="container-wide relative">
      <div class="max-w-3xl mb-16">
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs bg-line-dark border border-line-dark text-muted-dark mb-6">
          <span class="w-1.5 h-1.5 bg-ember rounded-full"></span> 安全核心
        </div>
        <h2 class="text-display-md md:text-5xl leading-tight">
          你的密钥，<br/><span class="italic text-ember">握在自己手里</span>。
        </h2>
        <p class="mt-6 text-xl text-muted-dark leading-relaxed">

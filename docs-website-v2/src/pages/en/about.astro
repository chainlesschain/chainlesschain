---
import BaseLayout from '../../layouts/BaseLayout.astro';
import rootPkg from '../../../../package.json';

const PRODUCT_VERSION = rootPkg.productVersion;

const milestones = [
  { date: '2025', title: 'Company Founded', body: 'Incorporated in Xiamen Free Trade Zone · MLPS Level 3 · ICP filing' },
  { date: 'Late 2025', title: 'v1.0 Launch', body: 'CLI + Desktop dual form factor · First npm release' },
  { date: '2026 Q1', title: 'v3.0', body: 'Multimodal Agent · Pipeline Orchestrator · NL Programming' },
  { date: 'Late 2026 Q1', title: 'v4.0', body: 'Agent Federation · Android 28 Skills · Deep Agents Deploy' },
  { date: '2026-04', title: 'v5.0.2.x', body: '139 skills / 109 CLI commands · 220+ V2 governance surfaces · 14,800+ tests' },
  { date: '2026-05', title: PRODUCT_VERSION, body: 'Web Shell default · MTC v0.11 cross-federation · Bilingual Web Panel' },
];
---
<BaseLayout
  title="About — Xiamen Chainlesschain Technology | ChainlessChain"
  description="Xiamen Chainlesschain Technology Co., Ltd. — focused on decentralized personal AI management systems. Address: Xiamen Free Trade Zone. Inquiries: 400-1068-687."
  canonical="https://www.chainlesschain.com/en/about"
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-paper opacity-60 pointer-events-none"></div>
    <div class="container-wide relative pt-20 pb-24 md:pt-28 md:pb-32">
      <div class="max-w-4xl">
        <div class="chip mb-6 animate-fade-in">About</div>
        <h1 class="animate-fade-in-delay font-display text-6xl md:text-display-lg leading-[1.02]">
          We believe<br/>data sovereignty<br/><span class="italic text-ember">belongs to every individual</span>.
        </h1>
        <p class="animate-fade-in-delay-2 mt-8 text-xl text-muted leading-relaxed max-w-3xl">
          Xiamen Chainlesschain Technology · ChainlessChain · Building decentralized personal AI management systems from research to enterprise deployment.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide grid md:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-4xl mb-6">The Company</h2>
        <div class="space-y-4 text-muted leading-relaxed">
          <p>We're a technology company focused on hardware-grade encryption and on-device AI. We believe the future of AI isn't a cloud-side black box — it's a tool every individual can hold and control.</p>
          <p>Since 2020 we've stitched together U-Key / SIMKey hardware encryption, the Signal protocol, and local Ollama inference into a complete personal AI substrate. We don't resell cloud services, and we don't broker user data.</p>
          <p>Code is open source. Protocols are open. Audits are welcome.</p>
        </div>
      </div>
      <div>
        <h2 class="font-display text-4xl mb-6">The Team</h2>
        <div class="space-y-4 text-muted leading-relaxed">
          <p>The team comes from internet security, blockchain, AI algorithms, and hardware encryption — averaging 8+ years of industry experience.</p>
          <p>We co-authored the China Mobile Communications Association group standard <em>Artificial Intelligence — Technical Requirements for Intrinsic Security of Agent</em> (<a href="https://www.ttbz.org.cn/StandardManage/Detail/162166/" target="_blank" rel="noopener" class="font-mono text-ink hover:text-ember">T/ZGCMCA 023—2025</a>), drafted jointly with CAICT and ~30 other institutions, hold 4 invention patents, and have completed MLPS Level 3 certification.</p>
          <p>What we care about most: making "data sovereignty" a value that lives in every line of code we write.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section class="py-16 border-t border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-12">
        <div class="chip mb-6">Milestones</div>
        <h2 class="font-display text-4xl md:text-5xl leading-tight">
          From v1.0 dual launch<br/>to <span class="italic text-ember">{PRODUCT_VERSION}</span>.
        </h2>
      </div>

      <ol class="relative border-l-2 border-line ml-3 md:ml-6 space-y-10">
        {milestones.map((m) => (
          <li class="pl-8 md:pl-12 relative">
            <span class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-ember ring-4 ring-paper"></span>
            <div class="font-mono text-xs text-ember uppercase tracking-widest mb-2">{m.date}</div>
            <h3 class="font-display text-2xl mb-2">{m.title}</h3>
            <p class="text-muted leading-relaxed">{m.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-16 border-t border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-12">
        <div class="chip mb-6">Credentials</div>
        <h2 class="font-display text-4xl md:text-5xl leading-tight">
          Compliance and certifications,<br/><span class="italic text-ember">written into our credentials</span>.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-8 rounded-2xl border border-line bg-paper">
          <div class="font-mono text-xs text-ember uppercase tracking-widest mb-5">Achieved</div>
          <ul class="space-y-3 text-sm">
            <li class="flex gap-2"><span class="text-ember">✓</span><span>National Information System MLPS Level 3 evaluation</span></li>
            <li class="flex gap-2"><span class="text-ember">✓</span><span><em>Artificial Intelligence — Technical Requirements for Intrinsic Security of Agent</em> <a href="https://www.ttbz.org.cn/StandardManage/Detail/162166/" target="_blank" rel="noopener" class="font-mono text-ink/70 hover:text-ember">T/ZGCMCA 023—2025</a> (co-author, drafted jointly with CAICT et al.)</span></li>
            <li class="flex gap-2"><span class="text-ember">✓</span><span>MIIT ICP filing <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" class="text-ink/60 hover:text-ink">闽ICP备2025105973号-1</a></span></li>
            <li class="flex gap-2"><span class="text-ember">✓</span><span>4 invention patents and multiple software copyrights</span></li>
            <li class="flex gap-2"><span class="text-ember">✓</span><span>MCP community / Claude Agent SDK adapter</span></li>
          </ul>
        </div>
        <div class="p-8 rounded-2xl border border-dashed border-ember/40 bg-ember/5">
          <div class="font-mono text-xs text-ember uppercase tracking-widest mb-5">In Progress</div>
          <ul class="space-y-3 text-sm">
            <li class="flex gap-2"><span class="text-ember">→</span><span>ISO/IEC 27001 information security management</span></li>
            <li class="flex gap-2"><span class="text-ember">→</span><span>Commercial cryptography application security evaluation</span></li>
            <li class="flex gap-2"><span class="text-ember">→</span><span>Generative AI service algorithm filing</span></li>
            <li class="flex gap-2"><span class="text-ember">→</span><span>CMMI maturity certification</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-16 bg-cream/50 border-y border-line">
    <div class="container-wide grid md:grid-cols-2 gap-10">
      <div>
        <div class="font-mono text-xs text-muted uppercase tracking-wider mb-3">Address</div>
        <div class="font-display text-2xl leading-snug mb-2">Xiamen · Free Trade Zone</div>
        <div class="text-muted">Unit 431-H, Floor 4, Building C, Xiamen International Shipping Center, 93 Xiangyu Road</div>
      </div>
      <div>
        <div class="font-mono text-xs text-muted uppercase tracking-wider mb-3">Contact</div>
        <a href="tel:400-1068-687" class="block font-display text-2xl text-ember hover:text-ember-dark mb-2">400-1068-687</a>
        <a href="mailto:zhanglongfa@chainlesschain.com" class="text-muted hover:text-ink break-all">zhanglongfa@chainlesschain.com</a>
      </div>
    </div>
  </section>
</BaseLayout>

const packs = [
  { name: 'cli-knowledge-pack', type: 'direct', desc: 'note / search / session — knowledge commands' },
  { name: 'cli-identity-pack', type: 'direct', desc: 'did / auth / encrypt — identity & encryption' },
  { name: 'cli-infra-pack', type: 'direct', desc: 'db / services / doctor — infrastructure' },
  { name: 'cli-ai-query-pack', type: 'llm-query', desc: 'chat / ask / llm — smart Q&A' },
  { name: 'cli-agent-mode-pack', type: 'agent', desc: 'agent / cowork — multi-agent' },

---
<BaseLayout
  title="CLI — 144 commands · 139 skills · Your terminal is the AI workbench | ChainlessChain"
  description="ChainlessChain CLI: 144 top-level commands, 139 built-in skills, 9 Skill Packs, local Ollama + 10 LLM providers, MTC v0.5 federation + libp2p auto-discovery, bilingual Web Panel. Agent mode, Cowork multi-agent, MCP ecosystem — all in the terminal."
  canonical="https://www.chainlesschain.com/en/cli"
  locale="en"
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-paper opacity-60 pointer-events-none"></div>
    <div class="container-wide relative pt-20 pb-16 md:pt-28 md:pb-20">
      <div class="max-w-4xl">
        <div class="chip mb-6 animate-fade-in">CLI · v{CLI_VERSION}</div>
        <h1 class="animate-fade-in-delay font-display text-6xl md:text-display-lg leading-[1.02]">
          Your terminal,<br/><span class="italic text-ember">your AI workbench</span>.
        </h1>
        <p class="animate-fade-in-delay-2 mt-8 text-xl text-muted leading-relaxed max-w-3xl">
          144 top-level commands covering the full lifecycle from knowledge base to on-chain governance. Zero GUI dependency, plain text I/O — pipeable, scriptable, CI-ready.
        </p>

        <!-- Install tabs -->
        <div class="animate-fade-in-delay-3 mt-10">
          <div class="flex flex-wrap gap-2 mb-3" id="install-tabs">
            <button class="tab-btn font-mono text-xs px-3 py-1.5 rounded-md bg-ink text-cream" data-tab="npm">npm</button>
            <button class="tab-btn font-mono text-xs px-3 py-1.5 rounded-md bg-cream text-ink border border-line" data-tab="yarn">yarn</button>
            <button class="tab-btn font-mono text-xs px-3 py-1.5 rounded-md bg-cream text-ink border border-line" data-tab="pnpm">pnpm</button>
            <button class="tab-btn font-mono text-xs px-3 py-1.5 rounded-md bg-cream text-ink border border-line" data-tab="bun">bun</button>
          </div>
          <div class="term-window max-w-2xl">
            <div class="term-head">
              <span class="term-dot"></span><span class="term-dot"></span><span class="term-dot"></span>
              <span class="term-title">install</span>
            </div>
            <div class="term-body">
              <div data-tab-panel="npm"><span class="term-prompt">$</span> npm i -g chainlesschain</div>
              <div data-tab-panel="yarn" hidden><span class="term-prompt">$</span> yarn global add chainlesschain</div>
              <div data-tab-panel="pnpm" hidden><span class="term-prompt">$</span> pnpm add -g chainlesschain</div>
              <div data-tab-panel="bun" hidden><span class="term-prompt">$</span> bun add -g chainlesschain</div>
              <div class="term-comment mt-3"># Aliases: chainlesschain / cc / clc / clchain</div>
              <div class="term-out">$ cc --help</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Commands by category -->
  <section class="py-16 md:py-24">
    <div class="container-wide">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-4xl md:text-5xl">All 144 top-level commands</h2>
        <span class="font-mono text-sm text-muted">{categories.length} categories</span>
      </div>
      <div class="space-y-3">
        {categories.map((cat, i) => (
          <details class="group border border-line rounded-xl bg-paper overflow-hidden" open={i < 3}>
            <summary class="flex items-center justify-between cursor-pointer p-5 list-none">
              <div class="flex items-center gap-4">
                <span class="font-mono text-xs text-muted">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-display text-xl">{cat.name}</span>
                <span class="chip">{cat.cmds.length} items</span>
              </div>
              <span class="text-muted group-open:rotate-180 transition-transform">▾</span>
            </summary>
            <div class="px-5 pb-5 grid md:grid-cols-2 gap-2">
              {cat.cmds.map(([cmd, desc]) => (
                <div class="flex gap-3 items-start py-2 border-t border-line/60">
                  <code class="font-mono text-sm text-ember whitespace-nowrap">cc {cmd}</code>
                  <span class="text-sm text-muted flex-1">{desc}</span>
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 9 Skill Packs -->
  <section class="py-16 md:py-24 bg-cream/50 border-y border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-12">
        <div class="chip mb-6">CLI Skill Packs · 9 domain packs</div>
        <h2 class="text-4xl md:text-5xl leading-tight">
          One command,<br/><span class="italic text-ember">all skill bindings generated</span>.
        </h2>
        <p class="mt-6 text-lg text-muted">
          <code class="font-mono text-sm bg-paper border border-line px-2 py-0.5 rounded">cc skill sync-cli</code> generates 9 domain Skill Packs with 101 built-in tests — ready to use out of the box.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        {packs.map((p) => (
          <div class="p-6 rounded-xl bg-paper border border-line">
            <div class="flex items-center justify-between mb-2">
              <code class="font-mono text-sm text-ink">{p.name}</code>
              <span class="text-[10px] font-mono uppercase tracking-wider text-ember">{p.type}</span>
            </div>
            <p class="text-sm text-muted">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 text-center">
    <div class="container-wide">
      <h2 class="text-4xl md:text-5xl mb-6">Full API reference</h2>
      <p class="text-muted mb-8">Args, examples, configuration — all in the developer docs.</p>
      <a href="https://docs.chainlesschain.com/chainlesschain/cli.html" rel="noopener" class="btn-ember">Read CLI docs ↗</a>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.tab-btn');
      if (!btn) return;
      var tab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) {
        var active = b.dataset.tab === tab;
        b.classList.toggle('bg-ink', active); b.classList.toggle('text-cream', active);
        b.classList.toggle('bg-cream', !active); b.classList.toggle('text-ink', !active);
        b.classList.toggle('border', !active); b.classList.toggle('border-line', !active);
      });
      document.querySelectorAll('[data-tab-panel]').forEach(function (p) {
        p.hidden = p.dataset.tabPanel !== tab;
      });
    });
  </script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — ChainlessChain" canonical="https://www.chainlesschain.com/en/404">
  <section class="min-h-[60vh] flex items-center">
    <div class="container-wide text-center">
      <div class="font-mono text-xs text-ember mb-4">HTTP 404</div>
      <h1 class="font-display text-display-xl leading-none mb-6">Lost.</h1>
      <p class="text-muted text-xl mb-10">This path isn't on our map — but you can head back to the start.</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/en/" class="btn-ember">Back to home →</a>
        <a href="/en/cli" class="btn-ghost">See the CLI</a>
      </div>
    </div>
  </section>
</BaseLayout>

            b.href ? (
              <a href={b.href} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </a>
            ) : (
              <div class="flex items-center gap-2 text-sm text-muted">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </div>

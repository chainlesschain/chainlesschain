---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Terminal from '../../components/Terminal.astro';
import rootPkg from '../../../../package.json';
import cliPkg from '../../../../packages/cli/package.json';
import releaseSizes from '../../data/release-sizes.json';

const PRODUCT_VERSION = rootPkg.productVersion;
// Published npm CLI version (release-sizes.json, pinned at build by
// fetch-release-sizes.mjs from npm's `latest` dist-tag). Falls back to the
// in-repo package.json only if the registry fetch + cache both failed — that
// fallback can drift ahead of npm during dev, so the pinned value is the norm.
const CLI_VERSION = releaseSizes.cliVersion || cliPkg.version;
const ANDROID_TAG = releaseSizes.tag || PRODUCT_VERSION;
const ANDROID_VERSION = ANDROID_TAG;
const ANDROID_RELEASE_URL = `https://github.com/chainlesschain/chainlesschain/releases/tag/${ANDROID_TAG}`;
const androidArm64 = releaseSizes.sizes['android-arm64-v8a'];
const androidUniversal = releaseSizes.sizes['android-universal'];

const templates = [
  { id: 'doc-convert', name: 'Document Conversion', tools: 'pandoc · LibreOffice' },
  { id: 'media-process', name: 'Audio / Video', tools: 'ffmpeg · yt-dlp' },
  { id: 'data-analysis', name: 'Data Analysis', tools: 'pandas · matplotlib' },
  { id: 'web-research', name: 'Web Research', tools: 'curl · BeautifulSoup' },
  { id: 'image-process', name: 'Image Processing', tools: 'ImageMagick · Tesseract' },
  { id: 'code-helper', name: 'Code Helper', tools: 'Python · Node.js' },
  { id: 'system-admin', name: 'System Admin', tools: 'system commands' },
  { id: 'file-organize', name: 'File Organization', tools: 'pathlib · 7-Zip' },
  { id: 'network-tools', name: 'Network Tools', tools: 'curl · nslookup' },
];

const pillars = [
  {
    icon: '📚',
    title: 'Knowledge Base',
    en: 'Personal Second Brain',
    bullets: [
      'Notes / docs / chat history — your personal second brain',
      'Hybrid search: BM25 + Qdrant vectors',
      'Hierarchical memory 2.0: working → short → long → core',
      'RAG-powered Q&A · code knowledge graph',
    ],
  },
  {
    icon: '🌐',
    title: 'Decentralized Social',
    en: 'P2P Identity & Messaging',
    bullets: [
      'W3C DID v2 identity + verifiable credentials',
      'P2P end-to-end: Signal + libp2p + WebRTC',
      'Community / channel gossip cross-machine sync (v5.0.3.41+)',
      'Audit-grade Merkle envelopes + cross-machine distribution + external archival (B4 suite)',
      'Protocol bridge: ActivityPub · Nostr · Matrix',
      'Anti-censorship: Tor + domain fronting + satellite',
    ],
  },
  {
    icon: '💎',
    title: 'Trading Assistant',
    en: 'Multi-Chain Wallet & Bridge',
    bullets: [
      'Multi-chain wallets: EVM family + Solana',
      'Cross-chain bridge: HTLC atomic swap + messaging',
      'zk-SNARK / zk-STARK generated locally',
      'DAO governance v2 · quadratic voting · treasury',
    ],
  },
];

const everyday = [
  { icon: '📄', title: 'Document Conversion', example: 'Batch Word → PDF / Word → Markdown' },
  { icon: '🎬', title: 'Media Processing', example: 'Compress video, extract audio, transcode' },
  { icon: '📊', title: 'Data Analysis', example: 'CSV / Excel analysis + chart generation' },
  { icon: '🖼️', title: 'Image Processing', example: 'Batch compress, OCR text extraction' },
  { icon: '🔎', title: 'Web Research', example: 'Auto-search and summarize results' },
  { icon: '🧰', title: 'System Admin', example: 'Disk analysis, process audit, network test' },
];

const badges = [
  { icon: '🏆', label: '4 invention patents' },
  { icon: '🔒', label: 'Military-grade encryption' },
  { icon: '⭐', label: '17k+ Open VSX installs' },
  { icon: '✅', label: 'MLPS Level 3' },
  { icon: '📋', label: 'Co-author · Intrinsic Security of AI Agent (T/ZGCMCA 023—2025)', href: 'https://www.ttbz.org.cn/standardDetail.html?id=jy42azxbb1ymwtf6tm371ejs6jcuwz7' },
];
---
<BaseLayout
  title="ChainlessChain — Sovereignty for your data. Productivity at your fingertips."
  description="CLI-driven local AI × hardware-level encryption. 175 CLI commands, 146 built-in skills, U-Key/SIMKey hardware protection, Signal end-to-end encryption. Built for anyone who wants control over their own data."
  canonical="https://www.chainlesschain.com/en/"
  locale="en"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-grid-paper opacity-60 pointer-events-none"></div>
    <div class="absolute top-20 right-0 w-[500px] h-[500px] rounded-full bg-ember/10 blur-3xl pointer-events-none"></div>
    <div class="container-wide relative pt-20 pb-24 md:pt-28 md:pb-32">
      <div class="max-w-4xl">
        <div class="animate-fade-in flex items-center gap-3 mb-8 flex-wrap">
          <span class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> {PRODUCT_VERSION} · Evolution Edition</span>
          <span class="chip">CLI v{CLI_VERSION}</span>
          <span class="chip">175 commands</span>
          <a href="https://open-vsx.org/extension/chainlesschain/chainlesschain-ide" target="_blank" rel="noopener" class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> 🎉 VS Code extension · 17k+ installs on Open VSX</a>
          <a href="https://www.npmjs.com/package/chainlesschain" target="_blank" rel="noopener" class="chip"><span class="w-1.5 h-1.5 bg-ember rounded-full"></span> 📦 22k+ monthly npm downloads</a>
          <span class="chip">Web Shell (default)</span>
          <span class="chip">Bilingual Web Panel</span>
          <span class="chip">MTC v0.11</span>
        </div>

        <h1 class="animate-fade-in-delay font-display text-6xl md:text-display-lg leading-[1.02] tracking-tight">
          Data sovereignty<br/>
          <span class="italic">returned to you</span>,<br/>
          AI <span class="text-ember italic">at your fingertips</span>.
        </h1>

        <p class="animate-fade-in-delay-2 mt-8 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl">
          CLI-driven local AI × hardware-grade encryption.<br class="hidden md:block"/>
          Built for everyone who wants to own their data.
        </p>

        <div class="animate-fade-in-delay-3 mt-10 flex flex-wrap items-center gap-4">
          <button
            class="btn-primary group"
            data-copy="npm i -g chainlesschain"
            aria-label="Copy install command"
          >
            <span class="text-ember">$</span>
            <span>npm i -g chainlesschain</span>
            <span class="text-muted-dark text-xs ml-2 group-hover:text-cream">click to copy</span>
          </button>
          <a href="#security" class="btn-ghost">
            See the hardware crypto stack <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="animate-fade-in-delay-3 mt-14 pt-8 border-t border-line flex flex-wrap gap-x-8 gap-y-3">
          {badges.map((b) => (
            b.href ? (
              <a href={b.href} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </a>
            ) : (
              <div class="flex items-center gap-2 text-sm text-muted">
                <span class="text-base">{b.icon}</span>
                <span>{b.label}</span>
              </div>
            )
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 三大核心能力 -->
  <section class="py-20 md:py-28 border-b border-line">
    <div class="container-wide">
      <div class="max-w-3xl mb-14">
        <div class="chip mb-6">Product Positioning · Three Pillars</div>
        <h2 class="text-display-md md:text-5xl leading-tight">
          Knowledge · Social · Trading,<br/>
          <span class="italic text-ember">end-to-end, individual-first</span>.
        </h2>
        <p class="mt-6 text-xl text-muted leading-relaxed">
          One foundation — hardware security + on-device AI + true decentralization. Three pillars stand independently and compose freely.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {pillars.map((p) => (
          <div class="p-8 rounded-2xl border border-line bg-paper hover:border-ember hover:-translate-y-0.5 transition-all">
            <div class="text-3xl mb-4">{p.icon}</div>
            <h3 class="font-display text-2xl mb-1">{p.title}</h3>
            <div class="font-mono text-[10px] text-muted uppercase tracking-widest mb-5">{p.en}</div>
            <ul class="space-y-2 text-sm text-ink/80">
              {p.bullets.map((b) => (
                <li class="flex gap-2"><span class="text-ember shrink-0">·</span><span>{b}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-10 grid md:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">Privacy First</div>
          <div class="text-sm text-ink/80">End-to-end encryption · hardware security · zero-knowledge proofs — service operators can't see your data.</div>
        </div>
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">Truly Decentralized</div>
          <div class="text-sm text-ink/80">Local storage (SQLCipher AES-256) · P2P (libp2p) · self-sovereign identity (DID v2).</div>
        </div>
        <div class="p-5 rounded-xl bg-cream/50 border border-line">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">AI Native</div>
          <div class="text-sm text-ink/80">Local LLMs (Ollama / LLaMA / Qwen) · prompts never uploaded by default · AI search + agent orchestration.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Data Hub -->
  <section class="py-24 md:py-32 bg-ink text-cream relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 w-72 h-72 rounded-full bg-ember blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full bg-ember blur-3xl"></div>
    </div>

    <div class="container-wide relative">
      <div class="max-w-4xl mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-ember/15 border border-ember/30 mb-6">
          <span class="w-1.5 h-1.5 bg-ember rounded-full animate-pulse"></span>
          <span class="font-mono text-[11px] text-ember uppercase tracking-widest">Personal Data Hub · 50+ data sources, real-device working (v5.0.3.134)</span>
        </div>
        <h2 class="text-display-md md:text-5xl leading-tight font-display">
          Pull every digital footprint home —<br/>
          <span class="italic text-ember">into a vault that's yours alone.</span>
        </h2>
        <p class="mt-6 text-xl md:text-2xl text-cream/80 leading-relaxed">
          Email · WeChat · Alipay · 8 AI chatbots · 7 social platforms · shopping · travel · Android system data —<br class="hidden md:block"/>
          <span class="text-cream">22+ sources end-to-end pulled to local</span>, untouchable by anyone else.
        </p>
        <p class="mt-5 text-base text-cream/60 italic max-w-2xl">
          "Data sovereignty returned to individuals" is not a slogan — it's 22 real adapters, 5 built-in analysis skills, 1 local encrypted vault.
        </p>
      </div>

      <!-- 5-grid data source categories -->
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4 mb-12">
        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">📧</div>
          <div class="font-display text-lg mb-2">Email / Bills</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· IMAP across all mail providers</li>
            <li>· Alipay statement CSV / PDF</li>
            <li>· 6 template extractors (bill/order/travel)</li>
            <li>· PDF decryption + transactions</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🤖</div>
          <div class="font-display text-lg mb-2">AI Chat History</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· DeepSeek · Kimi · Tongyi</li>
            <li>· Zhipu · Hunyuan · Qianfan</li>
            <li>· Coze · Dreamina · Doubao</li>
            <li class="text-ember/80 font-mono text-[10px] pt-1">9 / 9 vendors wired</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">💬</div>
          <div class="font-display text-lg mb-2">Social Platforms</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· WeChat (SQLCipher)</li>
            <li>· QQ · Weibo · Bilibili</li>
            <li>· Douyin · Xiaohongshu</li>
            <li>· Telegram · WhatsApp</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🛍️</div>
          <div class="font-display text-lg mb-2">Shopping / Travel</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· Taobao · JD · Meituan</li>
            <li>· Amap · Baidu Map</li>
            <li>· Ctrip · 12306</li>
            <li>· Orders / logistics / footprints unified</li>
          </ul>
        </div>

        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">📱</div>
          <div class="font-display text-lg mb-2">System Data</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· Contacts · call log</li>
            <li>· SMS · location history</li>
            <li>· Android ADB backup</li>
            <li>· iOS iTunes encrypted</li>
          </ul>
        </div>
      </div>

      <!-- 3-feature pillars -->
      <div class="grid md:grid-cols-3 gap-4 mb-10">
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">Local Vault</div>
          <div class="text-sm text-cream/85 leading-relaxed">SQLCipher AES-256 on disk — data never leaves your device. Email passwords, chat keys, bill amounts all stay on your hardware.</div>
        </div>
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">5 Built-in Analysis Skills</div>
          <div class="text-sm text-cream/85 leading-relaxed">Consumption trends · travel profile · communication frequency · content preference · time distribution — LLM-callable. Ask "which three shops did I spend the most at last year?" — instant answer.</div>
        </div>
        <div class="p-5 rounded-xl bg-ember/[0.08] border border-ember/25">
          <div class="font-mono text-[10px] text-ember uppercase tracking-wider mb-2">Entity Resolver</div>
          <div class="text-sm text-cream/85 leading-relaxed">"Zhang San" / "张三" / "+86 138-xxxx" auto-resolved as the same person — relationship graphs across email/WeChat/contacts finally connect.</div>
        </div>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap gap-3 items-center">
        <a href="https://docs.chainlesschain.com/chainlesschain/personal-data-hub.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-ember text-ink font-medium hover:bg-ember/90 transition-colors">
          Full feature guide →
        </a>
        <a href="https://design.chainlesschain.com/Personal_Data_Hub_Architecture.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-cream/20 text-cream/80 hover:border-ember hover:text-cream transition-all">
          Architecture design ↗
        </a>
        <span class="text-xs font-mono text-cream/40 ml-2">travel / shopping / social / docs / music / video coverage · 9 / 9 AIChat vendors wired · WeChat MD5+Frida dual-path · desktop IM local read · pdh npm 0.4.51</span>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-cream/40 border-y border-line relative overflow-hidden">
    <div class="container-wide relative">
      <div class="max-w-4xl mb-16">
        <div class="chip mb-6">Core Pillar · Decentralized Social</div>
        <h2 class="text-display-md md:text-5xl leading-tight font-display">
          Add friends, message, post ——<br/>
          <span class="italic text-ember">with no platform in the middle.</span>
        </h2>
        <p class="mt-6 text-xl md:text-2xl text-muted leading-relaxed">
          Your identity is your own DID, messages are peer-to-peer end-to-end encrypted, communities sync across machines ——<br class="hidden md:block"/>
          <span class="text-ink">no one can ban your account, delete your posts, or read your DMs.</span>
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🪪</div>
          <div class="font-display text-lg mb-2">Self-sovereign DID v2</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· W3C DID + verifiable credentials VC / VP</li>
            <li>· Social recovery + cross-device roaming</li>
            <li>· Reputation aggregation, no central accounts</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🔒</div>
          <div class="font-display text-lg mb-2">End-to-end encrypted messaging</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· Signal protocol + libp2p + WebRTC</li>
            <li>· Keys live only on both ends</li>
            <li>· Offline add + signaling relay fallback</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">📞</div>
          <div class="font-display text-lg mb-2">Voice / video calls</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· WebRTC direct connect, sub-second setup</li>
            <li>· Full-screen lock-screen incoming calls</li>
            <li>· Local call history</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🌐</div>
          <div class="font-display text-lg mb-2">Communities / channels sync</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· gossip cross-node distribution</li>
            <li>· Audit-grade Merkle envelopes</li>
            <li>· External archiving, offline-safe</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🔗</div>
          <div class="font-display text-lg mb-2">Protocol fusion</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· ActivityPub C2S federation</li>
            <li>· Nostr NIP-01/04/09/25</li>
            <li>· Matrix threads & spaces</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-paper border border-line hover:border-ember/50 transition-all">
          <div class="text-2xl mb-3">🛡️</div>
          <div class="font-display text-lg mb-2">Anti-censorship transport</div>
          <ul class="space-y-1 text-xs text-ink/70 leading-relaxed">
            <li>· Tor + domain fronting</li>
            <li>· Satellite message channel</li>
            <li>· Multi-hop routing + cross-federation trust anchors</li>
          </ul>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 items-center">
        <a href="https://docs.chainlesschain.com/chainlesschain/social.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-ember text-ink font-medium hover:bg-ember/90 transition-colors">
          Decentralized social, in depth →
        </a>
        <a href="https://docs.chainlesschain.com/chainlesschain/did-v2.html" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-line text-muted hover:border-ember hover:text-ink transition-all">
          DID v2 identity ↗
        </a>
        <span class="text-xs font-mono text-muted ml-2">Signal + libp2p + WebRTC · DID v2 + VC/VP · ActivityPub / Nostr / Matrix · voice & video calls</span>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 bg-ink text-cream relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 right-10 w-80 h-80 rounded-full bg-ember blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 rounded-full bg-ember blur-3xl"></div>
    </div>

    <div class="container-wide relative">
      <div class="max-w-4xl mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-ember/15 border border-ember/30 mb-6">
          <span class="w-1.5 h-1.5 bg-ember rounded-full"></span>
          <span class="font-mono text-[11px] text-ember uppercase tracking-widest">Core Pillar · Digital Asset Trading</span>
        </div>
        <h2 class="text-display-md md:text-5xl leading-tight font-display">
          Your wallet, your keys,<br/>
          <span class="italic text-ember">your assets.</span>
        </h2>
        <p class="mt-6 text-xl md:text-2xl text-cream/80 leading-relaxed">
          Multi-chain + cross-chain + zero-knowledge, signing entirely on-device ——<br class="hidden md:block"/>
          <span class="text-cream">private keys never leave your device — no custody, no middlemen.</span>
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">👛</div>
          <div class="font-display text-lg mb-2">Multi-chain self-custody wallet</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· EVM chains + Solana</li>
            <li>· Local keys, hardware U-Key protection</li>
            <li>· Assets / balances / history aggregation</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🌉</div>
          <div class="font-display text-lg mb-2">Cross-chain interoperability</div>
          <ul class="space-y-1 text-xs text-cream/65 leading-relaxed">
            <li>· HTLC atomic swaps</li>
            <li>· Cross-chain messaging + bridging</li>
            <li>· Multi-sig swap / send</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-cream/[0.03] border border-cream/10 hover:border-ember/40 transition-all">
          <div class="text-2xl mb-3">🔐</div>

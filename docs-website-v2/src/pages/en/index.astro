  description="CLI-driven local AI × hardware-level encryption. 160 CLI commands, 146 built-in skills, U-Key/SIMKey hardware protection, Signal end-to-end encryption. Built for anyone who wants control over their own data."
  canonical="https://www.chainlesschain.com/en/"
  locale="en"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">

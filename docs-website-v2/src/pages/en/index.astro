---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Terminal from '../../components/Terminal.astro';
import rootPkg from '../../../../package.json';
import cliPkg from '../../../../packages/cli/package.json';

const PRODUCT_VERSION = rootPkg.productVersion;
const CLI_VERSION = cliPkg.version;

const templates = [
  { id: 'doc-convert', name: 'Document Conversion', tools: 'pandoc · LibreOffice' },
  { id: 'media-process', name: 'Audio / Video', tools: 'ffmpeg · yt-dlp' },
  { id: 'data-analysis', name: 'Data Analysis', tools: 'pandas · matplotlib' },
  { id: 'web-research', name: 'Web Research', tools: 'curl · BeautifulSoup' },
  { id: 'image-process', name: 'Image Processing', tools: 'ImageMagick · Tesseract' },
  { id: 'code-helper', name: 'Code Helper', tools: 'Python · Node.js' },
  { id: 'system-admin', name: 'System Admin', tools: 'system commands' },
  { id: 'file-organize', name: 'File Organization', tools: 'pathlib · 7-Zip' },
  { id: 'network-tools', name: 'Network Tools', tools: 'curl · nslookup' },
];

const pillars = [
  {
    icon: '📚',
    title: 'Knowledge Base',
    en: 'Personal Second Brain',
    bullets: [
      'Notes / docs / chat history — your personal second brain',
      'Hybrid search: BM25 + Qdrant vectors',
      'Hierarchical memory 2.0: working → short → long → core',
      'RAG-powered Q&A · code knowledge graph',
    ],
  },
  {
    icon: '🌐',
    title: 'Decentralized Social',
    en: 'P2P Identity & Messaging',
    bullets: [
      'W3C DID v2 identity + verifiable credentials',
      'P2P end-to-end: Signal + libp2p + WebRTC',
      'Community / channel gossip cross-machine sync (v5.0.3.41+)',
      'Audit-grade Merkle envelopes + cross-machine distribution + external archival (B4 suite)',
      'Protocol bridge: ActivityPub · Nostr · Matrix',
      'Anti-censorship: Tor + domain fronting + satellite',
    ],
  },
  {
    icon: '💎',
    title: 'Trading Assistant',
    en: 'Multi-Chain Wallet & Bridge',
    bullets: [
      'Multi-chain wallets: EVM family + Solana',
      'Cross-chain bridge: HTLC atomic swap + messaging',
      'zk-SNARK / zk-STARK generated locally',
      'DAO governance v2 · quadratic voting · treasury',

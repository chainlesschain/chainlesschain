# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files to always use LF + UTF-8
*.js text eol=lf encoding=utf-8
*.ts text eol=lf encoding=utf-8
*.tsx text eol=lf encoding=utf-8
*.jsx text eol=lf encoding=utf-8
*.vue text eol=lf encoding=utf-8
*.json text eol=lf encoding=utf-8
*.md text eol=lf encoding=utf-8
*.yml text eol=lf encoding=utf-8
*.yaml text eol=lf encoding=utf-8
*.css text eol=lf encoding=utf-8
*.scss text eol=lf encoding=utf-8
*.html text eol=lf encoding=utf-8
*.xml text eol=lf encoding=utf-8
*.sql text eol=lf encoding=utf-8
*.sh text eol=lf encoding=utf-8
*.py text eol=lf encoding=utf-8
*.java text eol=lf encoding=utf-8
*.txt text eol=lf encoding=utf-8

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.db binary
*.sqlite binary

# Windows-specific files that need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

{
  "name": "chainlesschain",
  "version": "0.156.6",
  "description": "CLI for ChainlessChain - install, configure, and manage your personal AI management system",
  "type": "module",
  "bin": {
    "chainlesschain": "./bin/chainlesschain.js",
    "cc": "./bin/chainlesschain.js",
    "clc": "./bin/chainlesschain.js",
    "clchain": "./bin/chainlesschain.js"
  },
  "main": "src/index.js",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit/",
    "test:integration": "vitest run __tests__/integration/",
    "test:e2e": "vitest run __tests__/e2e/",
    "test:watch": "vitest watch",
    "lint": "eslint src/ bin/ --ext .js",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\" \"__tests__/**/*.js\"",
    "sync-skill-packs": "node --input-type=module -e \"import { generateCliPacks } from './src/lib/skill-packs/generator.js'; const r = await generateCliPacks({ force: false }); console.log('Skill packs synced:', r.generated.length, 'generated,', r.skipped.length, 'skipped');\"",
    "postinstall": "node scripts/postinstall.mjs",
    "build:web-panel": "node scripts/build-web-panel.mjs",
    "build:web-panel:force": "node scripts/build-web-panel.mjs --force",
    "prepublishOnly": "npm run build:web-panel"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "keywords": [
    "chainlesschain",
    "ai",
    "cli",
    "electron",
    "decentralized",
    "knowledge-base"
  ],
  "author": "ChainlessChain Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chainlesschain/chainlesschain.git",
    "directory": "packages/cli"
  },
  "homepage": "https://www.chainlesschain.com",
  "dependencies": {
    "@chainlesschain/core-config": "0.1.0",
    "@chainlesschain/core-db": "0.1.0",
    "@chainlesschain/core-env": "0.1.0",
    "@chainlesschain/core-infra": "0.1.0",
    "@chainlesschain/session-core": "0.3.1",
    "@chainlesschain/shared-logger": "0.1.0",
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "semver": "^7.6.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@noble/curves": "^1.9.7",
    "@scure/base": "^1.2.6",
    "@yao-pkg/pkg": "^6.18.2",
    "vitest": "^3.1.1"
  }
}

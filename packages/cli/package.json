{
  "name": "chainlesschain",
  "version": "0.162.175",
  "description": "CLI for ChainlessChain - install, configure, and manage your personal AI management system",
  "type": "module",
  "bin": {
    "chainlesschain": "./bin/chainlesschain.js",
    "cc": "./bin/chainlesschain.js",
    "clc": "./bin/chainlesschain.js",
    "clchain": "./bin/chainlesschain.js"
  },
  "main": "src/index.js",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit/",
    "test:integration": "vitest run __tests__/integration/",
    "test:e2e": "vitest run --config vitest.e2e.config.js __tests__/e2e/",
    "test:all": "vitest run && vitest run --config vitest.e2e.config.js __tests__/e2e/",
    "test:watch": "vitest watch",
    "lint": "eslint src/ bin/ --ext .js",
    "format": "prettier --write \"src/**/*.js\" \"bin/**/*.js\" \"__tests__/**/*.js\"",
    "sync-skill-packs": "node --input-type=module -e \"import { generateCliPacks } from './src/lib/skill-packs/generator.js'; const r = await generateCliPacks({ force: false }); console.log('Skill packs synced:', r.generated.length, 'generated,', r.skipped.length, 'skipped');\"",
    "docs:cli-reference": "node scripts/gen-cli-reference.mjs --out ../../docs/cli/CLI_REFERENCE.generated.md",
    "docs:cli-reference:check": "node scripts/gen-cli-reference.mjs --check ../../docs/cli/CLI_REFERENCE.generated.md",
    "docs:protocol": "node scripts/gen-protocol-doc.mjs --out ../../docs/cli/PROTOCOL_CAPABILITY_MANIFEST.generated.md",
    "docs:protocol:check": "node scripts/gen-protocol-doc.mjs --check ../../docs/cli/PROTOCOL_CAPABILITY_MANIFEST.generated.md",
    "docs:spawn-inventory": "node scripts/gen-process-spawn-inventory.mjs --out ../../docs/cli/PROCESS_SPAWN_INVENTORY.generated.md",
    "docs:spawn-inventory:check": "node scripts/gen-process-spawn-inventory.mjs --check ../../docs/cli/PROCESS_SPAWN_INVENTORY.generated.md",
    "postinstall": "node scripts/postinstall.mjs",
    "build:web-panel": "node scripts/build-web-panel.mjs",
    "build:web-panel:force": "node scripts/build-web-panel.mjs --force",
    "build:changelog": "node scripts/build-changelog.mjs",
    "runtime:convergence": "node scripts/test-runtime-convergence.mjs",
    "runtime:e2e": "node scripts/test-runtime-e2e.cjs",
    "runtime:test": "npm run runtime:convergence && npm run runtime:e2e",
    "prepublishOnly": "npm run build:web-panel && npm run build:changelog"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/postinstall.mjs",
    "README.md"
  ],
  "keywords": [
    "chainlesschain",
    "ai",
    "cli",
    "electron",
    "decentralized",
    "knowledge-base"
  ],
  "author": "ChainlessChain Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainlesschain/chainlesschain.git",
    "directory": "packages/cli"
  },
  "homepage": "https://www.chainlesschain.com",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@chainlesschain/core-config": "0.1.1",
    "@chainlesschain/core-db": "0.1.3",
    "@chainlesschain/core-env": "0.1.1",
    "@chainlesschain/core-infra": "0.1.0",
    "@chainlesschain/core-mtc": "0.2.2",
    "@chainlesschain/core-multisig": "0.1.3",
    "@chainlesschain/personal-data-hub": "0.4.51",
    "@chainlesschain/session-core": "0.3.3",
    "@chainlesschain/shared-logger": "0.1.0",
    "@inquirer/prompts": "^7.2.0",
    "@noble/curves": "^1.9.7",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "js-yaml": "^3.14.0",
    "ora": "^8.1.1",
    "semver": "^7.6.3",
    "sql.js": "^1.14.1",
    "webdav": "^5.10.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@scure/base": "^1.2.6",
    "@yao-pkg/pkg": "^6.18.2",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.1.0",
    "node-pty": "^1.0.0",
    "pdf-parse": "^1.1.1"
  },
  "peerDependencies": {
    "playwright": "^1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}

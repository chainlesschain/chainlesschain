[
  {
    "name": "explicit usable setting wins outright",
    "input": {
      "configured": { "path": "C:/tools/cc.cmd", "usable": true },
      "global": { "binary": "cc", "version": "0.162.158" },
      "managed": {
        "command": "/store/managed-cli/cc-managed",
        "version": "0.162.158"
      },
      "managedEnabled": true,
      "nodeOnPath": true,
      "floorVersion": "0.162.47"
    },
    "expected": {
      "use": "explicit",
      "command": "C:/tools/cc.cmd",
      "offerManaged": false,
      "diagnostics": []
    }
  },
  {
    "name": "broken explicit path is NEVER silently replaced — managed only OFFERED",
    "input": {
      "configured": { "path": "C:/broken/cc.cmd", "usable": false },
      "global": { "binary": "chainlesschain", "version": "0.162.158" },
      "managed": {
        "command": "/store/managed-cli/cc-managed",
        "version": "0.162.158"
      },
      "managedEnabled": true,
      "nodeOnPath": true,
      "floorVersion": "0.162.47"
    },
    "expected": {
      "use": "explicit",
      "command": "C:/broken/cc.cmd",
      "offerManaged": true,
      "diagnostics": ["explicit-path-broken"]
    }
  },
  {
    "name": "broken explicit + managed disabled — no offer, says why",
    "input": {
      "configured": { "path": "/opt/cc-broken", "usable": false },
      "global": null,
      "managed": null,
      "managedEnabled": false,
      "nodeOnPath": true,
      "floorVersion": "0.162.47"
    },
    "expected": {
      "use": "explicit",
      "command": "/opt/cc-broken",
      "offerManaged": false,
      "diagnostics": ["explicit-path-broken", "managed-disabled"]
    }
  },
  {
    "name": "broken explicit + no node on PATH — managed impossible, exact diagnostic",

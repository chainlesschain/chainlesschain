{
  "name": "chainlesschain-ide",
  "displayName": "ChainlessChain IDE Bridge",
  "description": "Bridges the ChainlessChain `cc` agent CLI to VS Code: exposes the active selection, diagnostics, open editors, and native diff review as MCP tools the agent can call.",
  "version": "0.37.12",
  "publisher": "chainlesschain",
  "license": "MIT",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "chainlesschain",
    "cc",
    "agent",
    "mcp",
    "ai",
    "ide bridge"
  ],
  "homepage": "https://docs.chainlesschain.com/chainlesschain/ide-bridge.html",
  "bugs": {
    "url": "https://github.com/chainlesschain/chainlesschain/issues"
  },
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./src/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "The IDE bridge exposes editor state and file-writing diff reviews to the local agent; it stays disabled until the workspace is trusted."
    }
  },
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "chainlesschain.ide.showStatus",
        "title": "%cmd.ide.showStatus.title%"
      },
      {
        "command": "chainlesschain.ide.restart",
        "title": "%cmd.ide.restart.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "chainlesschain.ide.openDashboard",
        "title": "%cmd.ide.openDashboard.title%",
        "icon": "$(dashboard)"
      },
      {
        "command": "chainlesschain.complete.trigger",
        "title": "%cmd.complete.trigger.title%"
      },
      {
        "command": "chainlesschain.ide.doctor",
        "title": "%cmd.ide.doctor.title%"
      },
      {
        "command": "chainlesschain.team.monitor",
        "title": "%cmd.team.monitor.title%",
        "icon": "$(organization)"
      },
      {
        "command": "chainlesschain.background.agents",
        "title": "%cmd.background.agents.title%",
        "icon": "$(server-process)"
      },
      {
        "command": "chainlesschain.remote.control",
        "title": "%cmd.remote.control.title%",
        "icon": "$(broadcast)"
      },
      {
        "command": "chainlesschain.usage.show",
        "title": "%cmd.usage.show.title%",
        "icon": "$(graph)"
      },
      {
        "command": "chainlesschain.plugins.manage",
        "title": "%cmd.plugins.manage.title%",
        "icon": "$(extensions)"
      },
      {
        "command": "chainlesschain.worktree.tasks",
        "title": "%cmd.worktree.tasks.title%",
        "icon": "$(git-branch)"
      },
      {
        "command": "chainlesschain.chrome.connector",
        "title": "%cmd.chrome.connector.title%",
        "icon": "$(globe)"
      },
      {
        "command": "chainlesschain.workspace.scanAutoExec",
        "title": "%cmd.workspace.scanAutoExec.title%",
        "icon": "$(shield)"
      },
      {
        "command": "chainlesschain.remote.doctor",
        "title": "%cmd.remote.doctor.title%",
        "icon": "$(pulse)"
      },
      {
        "command": "chainlesschain.lens.explain",
        "title": "%cmd.lens.explain.title%"
      },
      {
        "command": "chainlesschain.lens.refactor",
        "title": "%cmd.lens.refactor.title%"
      },
      {
        "command": "chainlesschain.diff.accept",
        "title": "%cmd.diff.accept.title%"
      },
      {
        "command": "chainlesschain.diff.reject",
        "title": "%cmd.diff.reject.title%"
      },
      {
        "command": "chainlesschain.memory.init",
        "title": "%cmd.memory.init.title%"
      },
      {
        "command": "chainlesschain.memory.files",
        "title": "%cmd.memory.files.title%"
      },
      {
        "command": "chainlesschain.llm.configure",
        "title": "%cmd.llm.configure.title%",
        "icon": "$(gear)"
      },
      {
        "command": "chainlesschain.llm.configureVision",
        "title": "%cmd.llm.configureVision.title%"
      },
      {
        "command": "chainlesschain.chat.insertReference",
        "title": "%cmd.chat.insertReference.title%"
      },
      {
        "command": "chainlesschain.chat.fixDiagnostics",
        "title": "%cmd.chat.fixDiagnostics.title%"
      },
      {
        "command": "chainlesschain.chat.explainSelection",
        "title": "%cmd.chat.explainSelection.title%"
      },
      {
        "command": "chainlesschain.chat.refactorSelection",
        "title": "%cmd.chat.refactorSelection.title%"
      },
      {
        "command": "chainlesschain.chat.newConversation",
        "title": "%cmd.chat.newConversation.title%",
        "icon": "$(add)"
      },
      {
        "command": "chainlesschain.chat.reopenClosedSession",
        "title": "%cmd.chat.reopenClosedSession.title%"
      },
      {
        "command": "chainlesschain.plan.approve",
        "title": "%cmd.plan.approve.title%",
        "icon": "$(check)"
      },
      {
        "command": "chainlesschain.plan.requestChanges",
        "title": "%cmd.plan.requestChanges.title%",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "chainlesschain.plan.regenerate",
        "title": "%cmd.plan.regenerate.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "chainlesschain.plan.reject",
        "title": "%cmd.plan.reject.title%",
        "icon": "$(close)"
      },
      {
        "command": "chainlesschain.preview.start",
        "title": "%cmd.preview.start.title%",
        "icon": "$(globe)"
      },
      {
        "command": "chainlesschain.preview.stop",
        "title": "%cmd.preview.stop.title%"
      },
      {
        "command": "chainlesschain.cli.upgrade",
        "title": "%cmd.cli.upgrade.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "chainlesschain.cli.checkUpdate",
        "title": "%cmd.cli.checkUpdate.title%",
        "icon": "$(sync)"
      },
      {
        "command": "chainlesschain.cli.whatsNew",
        "title": "%cmd.cli.whatsNew.title%",
        "icon": "$(sparkle)"
      }
    ],
    "keybindings": [
      {
        "command": "chainlesschainIdeChat.focus",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      },
      {
        "command": "chainlesschain.chat.insertReference",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "chainlesschain.complete.trigger",
        "key": "alt+\\",
        "mac": "alt+\\",
        "when": "editorTextFocus"
      },
      {
        "command": "chainlesschain.chat.newConversation",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "chainlesschain.chat.reopenClosedSession",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "focusedView == chainlesschainIdeChat"
      },
      {
        "command": "chainlesschain.diff.accept",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "chainlesschainDiffActive"
      },
      {
        "command": "chainlesschain.diff.reject",
        "key": "ctrl+shift+backspace",
        "mac": "cmd+shift+backspace",
        "when": "chainlesschainDiffActive"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chainlesschainIde",
          "title": "%view.container.title%",
          "icon": "media/logo-mark.png"
        }
      ]
    },
    "views": {
      "chainlesschainIde": [
        {
          "id": "chainlesschainIdeView",
          "name": "%view.status.name%"
        },
        {
          "id": "chainlesschainIdeChat",
          "name": "%view.chat.name%",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "chainlesschain.chat.insertReference",
          "group": "navigation@9"
        },
        {
          "command": "chainlesschain.chat.fixDiagnostics",
          "group": "navigation@10"
        },
        {
          "command": "chainlesschain.chat.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@11"
        },
        {
          "command": "chainlesschain.chat.refactorSelection",
          "when": "editorHasSelection",
          "group": "navigation@12"
        }
      ],
      "view/title": [
        {
          "command": "chainlesschain.chat.newConversation",
          "when": "view == chainlesschainIdeChat",
          "group": "navigation@0"
        },
        {
          "command": "chainlesschain.llm.configure",
          "when": "view == chainlesschainIdeChat",
          "group": "navigation@1"
        },
        {
          "command": "chainlesschain.llm.configureVision",
          "when": "view == chainlesschainIdeChat",
          "group": "1_config@1"
        },
        {
          "command": "chainlesschain.cli.checkUpdate",
          "when": "view == chainlesschainIdeChat",
          "group": "1_config@2"
        },
        {
          "command": "chainlesschain.cli.upgrade",
          "when": "view == chainlesschainIdeChat",
          "group": "1_config@3"
        },
        {
          "command": "chainlesschain.ide.openDashboard",
          "when": "view == chainlesschainIdeView",
          "group": "navigation@1"
        },
        {
          "command": "chainlesschain.ide.restart",
          "when": "view == chainlesschainIdeView",
          "group": "navigation@2"
        }
      ],
      "editor/title": [
        {
          "command": "chainlesschain.plan.approve",
          "when": "chainlesschainPlanReviewActive",
          "group": "navigation@0"
        },
        {
          "command": "chainlesschain.plan.requestChanges",
          "when": "chainlesschainPlanReviewActive",
          "group": "navigation@1"
        },
        {
          "command": "chainlesschain.plan.regenerate",
          "when": "chainlesschainPlanReviewActive",
          "group": "navigation@2"
        },
        {
          "command": "chainlesschain.plan.reject",
          "when": "chainlesschainPlanReviewActive",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "chainlesschain.lens.explain",
          "when": "false"
        },
        {
          "command": "chainlesschain.lens.refactor",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "chainlesschain.ide.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.ide.enabled.description%"
        },
        "chainlesschain.cli.path": {
          "type": "string",
          "default": "cc",
          "description": "%config.cli.path.description%"
        },
        "chainlesschain.chat.provider": {
          "type": "string",
          "default": "",
          "description": "%config.chat.provider.description%"
        },
        "chainlesschain.chat.model": {
          "type": "string",
          "default": "",
          "description": "%config.chat.model.description%"
        },
        "chainlesschain.chat.contextIndicator": {
          "type": "boolean",
          "default": true,
          "description": "%config.chat.contextIndicator.description%"
        },
        "chainlesschain.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.codeLens.enabled.description%"
        },
        "chainlesschain.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.completion.enabled.description%"
        },
        "chainlesschain.remote.relayUrl": {
          "type": "string",
          "default": "",
          "description": "%config.remote.relayUrl.description%"
        },
        "chainlesschain.remote.peerId": {
          "type": "string",
          "default": "",
          "description": "%config.remote.peerId.description%"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "publish:ovsx": "npx --yes ovsx publish --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chainlesschain/chainlesschain.git",
    "directory": "packages/vscode-extension"
  }
}

{
  "name": "chainlesschain-ide",
  "displayName": "ChainlessChain IDE Bridge",
  "description": "Bridges the ChainlessChain `cc` agent CLI to VS Code: exposes the active selection, diagnostics, open editors, and native diff review as MCP tools the agent can call.",
  "version": "0.31.0",
  "publisher": "chainlesschain",
  "license": "MIT",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "AI"],
  "keywords": [
    "chainlesschain",
    "cc",
    "agent",
    "mcp",
    "ai",
    "ide bridge"
  ],
  "homepage": "https://docs.chainlesschain.com/chainlesschain/ide-bridge.html",
  "bugs": {
    "url": "https://github.com/chainlesschain/chainlesschain/issues"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chainlesschain.ide.showStatus",
        "title": "ChainlessChain IDE: Show Bridge Status"
      },
      {
        "command": "chainlesschain.ide.restart",
        "title": "ChainlessChain IDE: Restart Bridge",
        "icon": "$(refresh)"
      },
      {
        "command": "chainlesschain.ide.openDashboard",
        "title": "ChainlessChain IDE: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "chainlesschain.memory.init",
        "title": "ChainlessChain: Generate Project Memory (cc.md)"
      },
      {
        "command": "chainlesschain.memory.files",
        "title": "ChainlessChain: Show Project Memory Files"
      },
      {
        "command": "chainlesschain.llm.configure",
        "title": "ChainlessChain: Configure LLM (配置大模型)",
        "icon": "$(gear)"
      },
      {
        "command": "chainlesschain.chat.insertReference",
        "title": "ChainlessChain: Insert File Reference into Chat (@file)"
      },
      {
        "command": "chainlesschain.chat.fixDiagnostics",
        "title": "ChainlessChain: Fix with ChainlessChain (diagnostics)"
      },
      {
        "command": "chainlesschain.chat.explainSelection",
        "title": "ChainlessChain: Explain Selection"
      },
      {
        "command": "chainlesschain.chat.refactorSelection",
        "title": "ChainlessChain: Refactor Selection"
      },
      {
        "command": "chainlesschain.chat.newConversation",
        "title": "ChainlessChain: New Chat Conversation",
        "icon": "$(add)"
      },
      {
        "command": "chainlesschain.chat.reopenClosedSession",
        "title": "ChainlessChain: Reopen Closed Chat"
      },
      {
        "command": "chainlesschain.preview.start",
        "title": "ChainlessChain: Start App Preview",
        "icon": "$(globe)"
      },
      {
        "command": "chainlesschain.preview.stop",
        "title": "ChainlessChain: Stop App Preview"
      },
      {
        "command": "chainlesschain.cli.upgrade",
        "title": "ChainlessChain: Upgrade CLI (npm i -g chainlesschain@latest)",
        "icon": "$(cloud-download)"
      }
    ],
    "keybindings": [
      {
        "command": "chainlesschainIdeChat.focus",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      },
      {
        "command": "chainlesschain.chat.insertReference",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "chainlesschain.chat.newConversation",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n"
      },
      {
        "command": "chainlesschain.chat.reopenClosedSession",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "focusedView == chainlesschainIdeChat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chainlesschainIde",
          "title": "ChainlessChain IDE",
          "icon": "media/logo-mark.png"
        }
      ]
    },
    "views": {
      "chainlesschainIde": [
        {
          "id": "chainlesschainIdeView",
          "name": "桥接状态"
        },
        {
          "id": "chainlesschainIdeChat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "chainlesschain.chat.insertReference",
          "group": "navigation@9"
        },
        {
          "command": "chainlesschain.chat.fixDiagnostics",
          "group": "navigation@10"
        },
        {
          "command": "chainlesschain.chat.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@11"
        },
        {
          "command": "chainlesschain.chat.refactorSelection",
          "when": "editorHasSelection",
          "group": "navigation@12"
        }
      ],
      "view/title": [
        {
          "command": "chainlesschain.chat.newConversation",
          "when": "view == chainlesschainIdeChat",
          "group": "navigation@0"
        },
        {
          "command": "chainlesschain.llm.configure",
          "when": "view == chainlesschainIdeChat",
          "group": "navigation@1"
        },
        {
          "command": "chainlesschain.ide.openDashboard",
          "when": "view == chainlesschainIdeView",
          "group": "navigation@1"
        },
        {
          "command": "chainlesschain.ide.restart",
          "when": "view == chainlesschainIdeView",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "ChainlessChain IDE Bridge",
      "properties": {
        "chainlesschain.ide.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run the IDE bridge MCP server so `cc agent` can auto-connect."
        },
        "chainlesschain.cli.path": {
          "type": "string",
          "default": "cc",
          "description": "Path to the ChainlessChain CLI executable the chat panel spawns (default: `cc` from PATH; install with `npm i -g chainlesschain`)."
        },
        "chainlesschain.chat.provider": {
          "type": "string",
          "default": "",
          "description": "LLM provider for the chat panel (e.g. ollama, anthropic, volcengine). Empty = the CLI's configured default."
        },
        "chainlesschain.chat.model": {
          "type": "string",
          "default": "",
          "description": "Model for the chat panel (e.g. qwen2.5:7b). Empty = the CLI's configured default."
        },
        "chainlesschain.chat.contextIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show a persistent context-window usage line (tokens used / window) under the chat, refreshed after each turn."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "publish:ovsx": "npx --yes ovsx publish --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chainlesschain/chainlesschain.git",
    "directory": "packages/vscode-extension"
  }
}

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- v1.2 #20 P0.2: Wear OS app —— 独立 APK，applicationId 同 phone -->
    <!-- per https://developer.android.com/training/wearables/get-started/creating -->

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Phase 2 BiometricPrompt 需要 (Wear OS 4+) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!-- 内部通知 channel (Wear-side fallback) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".WearApplication"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="ChainlessChain Wear"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Wear OS marker — required for Play Store filtering & companion pairing -->
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!-- 让 Play Console 把本 APK 标 standalone — 不强制 phone 端先装 -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".WearMainActivity"
            android:exported="true"
            android:label="ChainlessChain"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- v1.2 Wear Phase 2: approval screen with BiometricPrompt -->
        <activity
            android:name=".WearApprovalActivity"
            android:exported="false"
            android:label="审批"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar" />

        <!--
            #21 C.1 PR3: invisible trampoline that wear tile / complication tap
            launches; it fires WearVoiceSender → /cc/voice/start to phone and
            finishes immediately. android:noHistory keeps the back-stack clean
            so repeated wear taps don't accumulate stale entries.
        -->
        <activity
            android:name=".VoiceForwardActivity"
            android:exported="false"
            android:label="语音对话"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar" />

        <!-- v1.2 Wear Phase 3: pending approvals Tile -->
        <service
            android:name=".tile.PendingApprovalsTileService"
            android:exported="true"
            android:label="待审批"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <!-- Tile preview shown in Watch face customization picker -->
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:value="@android:drawable/sym_def_app_icon" />
        </service>

        <!-- v1.2 Wear Phase 3: complication data source -->
        <service
            android:name=".tile.PendingApprovalsComplicationService"
            android:exported="true"
            android:icon="@android:drawable/sym_def_app_icon"
            android:label="待审批数"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="0" />
        </service>

        <!--
            #21 C.1 PR3: Voice shortcut tile. Users add via wear watch face
            tile editor; tile carousel page shows "对话" big button → tap
            launches VoiceForwardActivity → wear→phone /cc/voice/start.
        -->
        <service
            android:name=".tile.VoiceShortcutTileService"
            android:exported="true"
            android:label="语音对话"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:value="@android:drawable/sym_def_app_icon" />
        </service>

        <!--
            #21 C.1 PR3: Voice complication. Users add via watch face
            complication slot; tap fires VoiceForwardActivity (same as tile).
            Content is static "对话" / "语音" — no UPDATE_PERIOD needed.
        -->
        <service
            android:name=".tile.VoiceComplicationService"
            android:exported="true"
            android:icon="@android:drawable/sym_def_app_icon"
            android:label="语音对话"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="0" />
        </service>

        <!-- v1.2 Wear Phase 1: 接收 phone → watch Wearable Data Layer push -->
        <service
            android:name=".sync.CcWearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <!-- pathPrefix 限 /cc/，让其它 Wearable app 的 message 不抖动 service -->
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/cc/" />
            </intent-filter>
        </service>

        <!-- Phase 3 registers TileService + ComplicationDataSourceService -->

    </application>
</manifest>

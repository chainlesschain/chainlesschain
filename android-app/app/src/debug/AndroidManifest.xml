<?xml version="1.0" encoding="utf-8"?>
<!--
  仅 debug 构建合并的 manifest (release 不含)。声明 DebugVerifyActivity:
  无 UI、可被 `adb shell am start` 触发的真机验证入口, 用于绕过 MIUI 输入注入限制做端到端验证。
  exported=true 仅在 debug 下生效, 不影响 release 安全面。
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <activity
            android:name="com.chainlesschain.android.debug.DebugVerifyActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
    </application>
</manifest>

<?xml version="1.0" encoding="utf-8"?>
<!--
  androidTest manifest for feature-ai.

  Existence reason: feature-ai (minSdk=26) depends on feature-local-terminal
  (minSdk=28 — required for NDK spawn.h, see feature-local-terminal/
  build.gradle.kts). AGP's manifest merger is strict on the androidTest
  variant and refuses the implicit minSdk bump that works for the main
  APK build. Without this override, every Android E2E Tests run trips on:

    Manifest merger failed: uses-sdk:minSdkVersion 26 cannot be smaller
    than version 28 declared in library [:feature-local-terminal]

  The actual androidTest .kt files have been quarantined (renamed .kt.broken
  — see same-commit diff) because they reference test infrastructure that
  was never plumbed (MainActivity from :app, com.chainlesschain.android.test.*
  Hilt test helpers that don't exist, etc.). Restoring them is a follow-up
  scoped at the feature-ai androidTest module rewrite, not Phase 5.8.

  Once those .kt.broken files are rewritten and re-enabled, you may want
  to revisit this override: either bump feature-ai minSdk to 28 (consistent
  with feature-local-terminal), or keep this override if 26 must stay.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-sdk
        android:minSdkVersion="26"
        tools:overrideLibrary="com.chainlesschain.android.feature.localterminal" />

    <application android:name="dagger.hilt.android.testing.HiltTestApplication">
        <!--
            Module-local host Activity for createAndroidComposeRule<TestActivity>()
            in androidTest. Hilt-aware via @AndroidEntryPoint. Replaces the
            never-existed `:app/MainActivity` reverse-dep the 10 stubbed
            AIConversationE2ETest tests referenced. See
            src/androidTest/.../TestActivity.kt KDoc.
        -->
        <!--
            android:name MUST be fully-qualified — see :feature-knowledge
            sibling manifest KDoc for the runtime "Unable to resolve activity"
            failure that `.TestActivity` (relative) caused on run 26493612650.
        -->
        <activity
            android:name="com.chainlesschain.android.feature.ai.TestActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />
    </application>
</manifest>

{
  "name": "chainlesschain-desktop-vue",
  "version": "5.0.3-alpha.71",
  "description": "ChainlessChain桌面应用 - 基于Electron和Vue3的个人AI知识库",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.12.0 <23.0.0 || >=24.0.0",
    "npm": ">=10.0.0",
    "_comment": "Node 23 (ABI v131) intentionally excluded — native deps like better-sqlite3-multiple-ciphers and SIMKey FFI ship prebuilds for v115/v127/v137 only, so 23.x falls back to node-gyp from-source builds and breaks `npm install` on machines without MSVC. Use 22.x LTS (recommended) or 24.x."
  },
  "scripts": {
    "_postinstall_disabled": "node scripts/link-hoisted-modules.js",
    "postinstall": "node node_modules/electron/install.js || true",
    "predev": "node scripts/fix-broken-bin-shims.js",
    "dev": "npm run build:main && npx concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env CHAINLESSCHAIN_DISABLE_NATIVE_DB=1 ELECTRON_DISABLE_SECURITY_WARNINGS=true NODE_ENV=development electron .",
    "dev:renderer": "vite",
    "predev:web-shell": "node scripts/fix-broken-bin-shims.js",
    "dev:web-shell": "npm run build:main && cross-env CHAINLESSCHAIN_WEB_SHELL=1 CHAINLESSCHAIN_DISABLE_NATIVE_DB=1 ELECTRON_DISABLE_SECURITY_WARNINGS=true NODE_ENV=development electron . --web-shell",
    "predev:no-web-shell": "node scripts/fix-broken-bin-shims.js",
    "dev:no-web-shell": "npm run build:main && npx concurrently \"npm run dev:renderer\" \"npm run dev:electron:no-web-shell\"",
    "dev:electron:no-web-shell": "wait-on http://127.0.0.1:5173 && cross-env CHAINLESSCHAIN_WEB_SHELL=0 CHAINLESSCHAIN_DISABLE_NATIVE_DB=1 ELECTRON_DISABLE_SECURITY_WARNINGS=true NODE_ENV=development electron . --no-web-shell",
    "prestart": "node scripts/fix-broken-bin-shims.js",
    "start": "cross-env CHAINLESSCHAIN_DISABLE_NATIVE_DB=1 ELECTRON_DISABLE_SECURITY_WARNINGS=true NODE_ENV=development electron .",
    "prebuild": "node scripts/fix-broken-bin-shims.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "node scripts/build-main.js",
    "build:renderer": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --ext .js,.vue --fix",
    "lint:strict": "eslint src --ext .js,.vue --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coding-agent:integration": "vitest run tests/integration/coding-agent-hosted-tools.integration.test.js",
    "test:coding-agent:mvp": "node scripts/verify-coding-agent-mvp.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:health": "node tests/e2e/health-check.js",
    "test:e2e:all": "node tests/e2e/run-all-modules.js",
    "test:e2e:quick": "node tests/e2e/quick-validation.js",
    "test:e2e:report": "node tests/e2e/generate-report.js",
    "test:e2e:check": "node tests/e2e/quick-check.js",
    "test:performance": "vitest run tests/performance",
    "test:coverage": "vitest run --coverage",
    "test:db": "node scripts/test-database.js",
    "test:ukey": "node scripts/test-ukey.js",
    "test:pkcs11": "node scripts/test-pkcs11-encryption.js",
    "test:secure-storage": "node scripts/test-secure-storage.js",
    "test:data": "node scripts/test-data-engine.js",
    "test:hooks": "vitest run src/main/hooks/__tests__/hook-system.test.js",
    "test:hooks:integration": "node scripts/test-hooks-integration.js",
    "test:plan-mode": "vitest run src/main/ai-engine/plan-mode/__tests__/plan-mode.test.js",
    "test:plan-mode:integration": "node scripts/test-plan-mode.js",
    "test:skills": "vitest run src/main/ai-engine/cowork/skills/__tests__",
    "test:skills:integration": "node scripts/test-markdown-skills.js",
    "test:context": "node scripts/test-context-engineering.js",
    "test:compressor": "node scripts/test-prompt-compressor.js",
    "test:cache": "node scripts/test-response-cache.js",
    "test:tracker": "node scripts/test-token-tracker.js",
    "test:stream": "node scripts/test-stream-controller.js",
    "test:resource": "node scripts/test-resource-monitor.js",
    "test:aggregator": "node scripts/test-message-aggregator.js",
    "test:progress": "node scripts/test-progress-emitter.js",
    "test:all": "npm run test && npm run test:db && npm run test:ukey && npm run test:data && npm run test:hooks && npm run test:plan-mode && npm run test:skills:integration && npm run test:context && npm run test:compressor && npm run test:cache && npm run test:tracker && npm run test:stream && npm run test:resource && npm run test:aggregator && npm run test:progress",
    "test:mcp": "vitest run tests/unit/mcp",
    "test:mcp:watch": "vitest watch tests/unit/mcp",
    "test:mcp:integration": "vitest run tests/integration/mcp-integration.test.js",
    "benchmark:mcp": "node scripts/benchmark-mcp.js",
    "test:signal": "node scripts/test-signal-encryption.js",
    "test:signal:unit": "vitest run tests/unit/p2p/signal-session-manager.test.js tests/unit/p2p/signal-security.test.js tests/unit/p2p/p2p-signal-driver-routing.test.js tests/unit/p2p/signal-driver-official.test.js",
    "test:signal:official": "node scripts/test-signal-official-driver.js",
    "test:signal:watch": "vitest watch tests/unit/p2p",
    "test:p2p": "vitest run tests/unit/p2p && node scripts/test-signal-encryption.js",
    "test:remote": "vitest run tests/remote/",
    "test:remote:all": "node scripts/test-remote-e2e.js",
    "benchmark:remote": "node scripts/benchmark-remote-performance.js",
    "test:workflow": "vitest run tests/ai-engine",
    "test:workflow:unit": "vitest run tests/ai-engine",
    "test:workflow:e2e:ui": "node scripts/test-workflow-e2e.js",
    "benchmark:workflow": "node scripts/benchmark-workflow-optimizations.js --compare",
    "benchmark:workflow:baseline": "node scripts/benchmark-workflow-optimizations.js --baseline",
    "benchmark:workflow:optimized": "node scripts/benchmark-workflow-optimizations.js --optimized",
    "test:runner": "node scripts/test-runner.js",
    "test:auto-fix": "node scripts/auto-fix-runner.js",
    "test:health": "node -e \"const { getHealthCheckService } = require('./src/main/health-check'); const service = getHealthCheckService(); service.runChecks().then(r => console.log(JSON.stringify(r, null, 2)));\"",
    "validate:rules": "node scripts/rules-validator.js",
    "scan:todos": "node scripts/scan-todos.js",
    "scan:todos:strict": "node scripts/scan-todos.js --strict",
    "fix:sql": "node scripts/fix-sql-injection.js",
    "fix:sql:apply": "node scripts/fix-sql-injection.js --apply",
    "security:audit": "npm audit --audit-level=high",
    "security:check": "npm run validate:rules && npm run security:audit",
    "docs:rules": "cat ../.chainlesschain/QUICK_REFERENCE.md",
    "docs:training": "cat ../.chainlesschain/TEAM_TRAINING.md",
    "example:database": "node ../.chainlesschain/examples/database-good.js",
    "example:p2p": "node ../.chainlesschain/examples/p2p-encryption-good.js",
    "fix:batch": "node scripts/batch-fix-sql-injection.js",
    "fix:batch:apply": "node scripts/batch-fix-sql-injection.js --apply",
    "contracts:install": "cd contracts && npm install --no-audit --no-fund",
    "contracts:test": "cd contracts && npm test",
    "contracts:compile": "cd contracts && npm run compile",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:win": "npm run build && electron-forge make --platform=win32",
    "make:mac": "npm run build && electron-forge make --platform=darwin",
    "make:mac:arm64": "npm run build && electron-forge make --platform=darwin --arch=arm64",
    "make:mac:x64": "npm run build && electron-forge make --platform=darwin --arch=x64",
    "make:linux": "npm run build && electron-forge make --platform=linux",
    "make:linux:x64": "npm run build && electron-forge make --platform=linux --arch=x64",
    "make:linux:deb": "npm run build && electron-forge make --platform=linux --arch=x64 --targets=@electron-forge/maker-deb,@electron-forge/maker-zip",
    "installer": "npm run package && build-installer.bat",
    "installer:check": "where iscc || echo Inno Setup not installed. Please install from https://jrsoftware.org/isdl.php",
    "publish": "electron-forge publish",
    "docs:generate": "node scripts/cowork-doc-generator.js --type all",
    "docs:api": "node scripts/cowork-doc-generator.js --type api",
    "docs:user-guide": "node scripts/cowork-doc-generator.js --type user-guide",
    "docs:changelog": "node scripts/cowork-doc-generator.js --type changelog",
    "docs:architecture": "node scripts/cowork-doc-generator.js --type architecture",
    "docs:preview": "node scripts/cowork-doc-generator.js --type all --dry-run",
    "release": "npm run docs:generate && node scripts/release.js",
    "release:draft": "npm run docs:generate && node scripts/release.js --draft",
    "release:skip-build": "node scripts/release.js --skip-build",
    "release:check": "npm run docs:generate && node scripts/pre-release-check.js",
    "release:builder": "npm run docs:generate && node scripts/release.js --builder",
    "release:builder:draft": "npm run docs:generate && node scripts/release.js --builder --draft",
    "release:verify": "node scripts/verify-release-artifacts.js",
    "prepare:cli-prod-deps": "cd ../packages/cli && npm install --no-package-lock --no-save --omit=dev --workspaces=false --legacy-peer-deps",
    "make:win:builder": "npm run prepare:cli-prod-deps && npm run build && node scripts/build-win-with-deref.js",
    "make:mac:builder": "npm run prepare:cli-prod-deps && npm run build && electron-builder --mac --config electron-builder.yml --publish never",
    "make:linux:builder": "npm run prepare:cli-prod-deps && npm run build && electron-builder --linux --config electron-builder.yml --publish never",
    "perf:benchmark": "node test-scripts/performance-benchmark.js",
    "perf:report": "node -e \"const { getPerformanceMonitor } = require('./utils/performance-monitor'); const m = getPerformanceMonitor(); m.printReport();\"",
    "perf:apply": "node scripts/apply-performance-config.js",
    "config:show": "node -e \"const { getPerformanceConfigManager } = require('./utils/performance-config-manager'); const c = getPerformanceConfigManager(); console.log(JSON.stringify(c.getConfigSummary(), null, 2));\"",
    "config:preset:balanced": "node -e \"const { getPerformanceConfigManager } = require('./utils/performance-config-manager'); const c = getPerformanceConfigManager(); c.applyPreset('balanced'); c.saveConfig();\"",
    "config:preset:high": "node -e \"const { getPerformanceConfigManager } = require('./utils/performance-config-manager'); const c = getPerformanceConfigManager(); c.applyPreset('high-performance'); c.saveConfig();\"",
    "db:optimize": "echo '数据库优化将在应用启动时自动运行'",
    "prepare": "husky"
  },

{
  "id": "terminal",
  "name": "远程终端",
  "version": "1.0.0",
  "firstParty": true,
  "description": "V6 shell 内置：/terminal 斜杠命令 + Home 页快捷卡片 — 桌面端托管 PTY，Android 远程操控 (Plan A)。",
  "extensionPoints": [
    {
      "point": "ui.slash",
      "priority": 10,
      "config": {
        "id": "terminal",
        "trigger": "/terminal",
        "handler": "builtin:openTerminalPanel",
        "description": "打开远程终端",
        "icon": "DesktopOutlined"
      }
    },
    {
      "point": "ui.home-widget",
      "priority": 10,
      "config": {
        "id": "terminal-quick",
        "component": "builtin:TerminalWidget",
        "size": "medium",
        "order": 150,
        "title": "远程终端"
      }
    }
  ]
}

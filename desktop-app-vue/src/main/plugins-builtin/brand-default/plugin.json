{
  "id": "brand-default",
  "name": "ChainlessChain 默认品牌",
  "version": "1.0.0",
  "firstParty": true,
  "description": "默认主题与品牌标识；企业 Profile 通过更高 priority 的贡献覆盖",
  "extensionPoints": [
    {
      "point": "brand.theme",
      "priority": 10,
      "config": {
        "id": "chainlesschain-default",
        "name": "ChainlessChain 默认",
        "mode": "light",
        "priority": 10,
        "tokens": {
          "primary": "#1677ff",
          "primary-hover": "#4096ff",
          "success": "#52c41a",
          "warning": "#faad14",
          "danger": "#f5222d",
          "shell-bg": "#ffffff",
          "shell-sider-bg": "#fafafa",
          "shell-artifact-bg": "#fcfcfc",
          "shell-footer-bg": "#f5f5f5",
          "shell-border": "#e8e8e8",
          "shell-muted": "#888888",
          "shell-radius": "6px",
          "shell-font": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif"
        }
      }
    },
    {
      "point": "brand.identity",
      "priority": 10,
      "config": {
        "id": "chainlesschain-default",
        "productName": "ChainlessChain",
        "tagline": "对话优先 · 硬件级安全 · 去中心化",
        "logo": "builtin:logo/default.svg",
        "splash": "builtin:splash/default.png",
        "favicon": "builtin:favicon/default.ico",
        "eula": null,
        "priority": 10,
        "links": {
          "homepage": "https://chainlesschain.org",
          "docs": "https://docs.chainlesschain.org",
          "support": "https://support.chainlesschain.org"
        }
      }
    }
  ]
}

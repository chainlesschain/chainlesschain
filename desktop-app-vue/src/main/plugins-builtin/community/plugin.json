      "config": {
        "id": "community",
        "trigger": "/community",
        "handler": "builtin:openCommunityPanel",
        "description": "打开社区面板",
        "icon": "TeamOutlined"
      }
    },
    {
      "point": "ui.home-widget",
      "priority": 10,
      "config": {
        "id": "community-quick",
        "component": "builtin:CommunityWidget",
        "size": "medium",
        "order": 120,
        "title": "社区"
      }
    }
  ]
}
